          <div class="journal-excerpt">{j.excerpt}</div>
          <div class="journal-read">Read More</div>
        </div>
      </a>
    ))}
  </div>
  <a href="https://curatedandcobkk.com/blog/" class="journal-more rv">All Stories</a>
</section>

<!-- OUR FAVOURITE -->
<section class="phil">
  <div>
    <span class="sec-ey rv">{favEyebrow}</span>
    <h2 class="sec-h2 rv d1">{favH1}<br/><em>{favH2}</em></h2>
    <p class="phil-body rv d2">{favBody}</p>
  </div>
  <div class="phil-rows">
