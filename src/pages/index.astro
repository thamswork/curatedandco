  </div>
</section>

<!-- INSTAGRAM -->
<section class="ig-sec">
  <div class="sec-hd">
    <span class="sec-ey rv">Instagram</span>
    <h2 class="sec-h2 rv d1">#Curated<br/><em>AndCoBkk</em></h2>
