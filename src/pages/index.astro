---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<title>Curated & Co. Bangkok</title>
<style>
@font-face{font-family:'K2D';src:url('/fonts/K2D-Light.ttf') format('truetype');font-weight:300;font-style:normal;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-LightItalic.ttf') format('truetype');font-weight:300;font-style:italic;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-Regular.ttf') format('truetype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-Italic.ttf') format('truetype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-Medium.ttf') format('truetype');font-weight:500;font-style:normal;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-SemiBold.ttf') format('truetype');font-weight:600;font-style:normal;font-display:swap}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
a{color:inherit;text-decoration:none}
:root{
  --green:#0D2B1F;--gold:#B8924A;--gold2:#CFA55A;
  --cream:#F7F4EF;--page:#FAFAF8;--ink:#111;--mid:#5A5A58;
  --ease:cubic-bezier(0.16,1,0.3,1);
  --f:'K2D','Cormorant Garamond',Georgia,serif;
}
html{scroll-behavior:smooth}
body{background:#000;color:var(--ink);font-family:var(--f);font-weight:300;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* SCROLL REVEALS */
.rv{opacity:0;transform:translateY(22px);transition:opacity 1s var(--ease),transform 1s var(--ease)}
.rv.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.22s}.d3{transition-delay:.34s}

/* NAV */
.nav{position:fixed;inset:0 0 auto 0;z-index:300;height:calc(64px + env(safe-area-inset-top));padding:env(safe-area-inset-top) 24px 0;display:flex;align-items:center;justify-content:space-between;transition:all .5s var(--ease)}
.nav.h{background:linear-gradient(to bottom,rgba(0,0,0,.55),transparent)}
.nav.l{background:var(--page);border-bottom:1px solid rgba(17,17,17,.07)}
.nav-logo img{height:36px;width:auto;object-fit:contain;transition:filter .4s}
.nav.h .nav-logo img{filter:brightness(0) invert(1)}
.nav.l .nav-logo img{filter:none}
.nav-right{display:flex;align-items:center;gap:20px}
.nav-shop{font-family:var(--f);font-size:10px;font-weight:400;letter-spacing:.2em;text-transform:uppercase;transition:color .4s;display:none}
.nav.h .nav-shop{color:rgba(255,255,255,.65)}
.nav.l .nav-shop{color:var(--green)}
.nav-burger{display:flex;flex-direction:column;gap:5px;align-items:flex-end;justify-content:center;min-width:44px;min-height:44px;cursor:pointer}
.nav-burger span{display:block;height:1px;transition:background .4s}
.nav.h .nav-burger span{background:rgba(255,255,255,.7)}
.nav.l .nav-burger span{background:var(--green)}
.nav-burger span:first-child{width:22px}
.nav-burger span:last-child{width:13px}

/* HERO */
.hero{position:relative;height:100svh;min-height:600px;overflow:hidden;background:#0a0a0a}
.hero-media{position:absolute;inset:0;z-index:1}
.hero-media video,.hero-media img{width:100%;height:100%;object-fit:cover;display:block}
.hero-overlay{position:absolute;inset:0;z-index:2;background:linear-gradient(to top,rgba(0,0,0,.78) 0%,rgba(0,0,0,.15) 50%,rgba(0,0,0,.05) 100%)}
.hero-body{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:0 28px calc(64px + env(safe-area-inset-bottom))}
.hero-eyebrow{font-size:8px;letter-spacing:.6em;text-transform:uppercase;color:rgba(255,255,255,.32);margin-bottom:12px;opacity:0;animation:fadeup .9s var(--ease) .3s forwards}
.hero-title-wrap{overflow:hidden;margin-bottom:8px}
.hero-title{font-family:var(--f);font-size:clamp(32px,9vw,48px);font-weight:300;color:rgba(255,255,255,.78);line-height:.95;opacity:0;transform:translateY(100%);animation:slideup 1s var(--ease) .5s forwards}
.hero-title em{font-style:italic;color:rgba(184,146,74,.68)}
.hero-sub{font-size:10px;font-weight:300;color:rgba(255,255,255,.28);letter-spacing:.05em;line-height:1.8;margin-bottom:28px;max-width:220px;opacity:0;animation:fadeup .9s var(--ease) .75s forwards}
.hero-cta{display:inline-flex;align-items:center;gap:10px;font-size:8px;font-weight:400;letter-spacing:.42em;text-transform:uppercase;color:rgba(255,255,255,.4);opacity:0;animation:fadeup .9s var(--ease) .95s forwards}
.hero-cta::after{content:'';width:22px;height:1px;background:rgba(255,255,255,.28);display:block}
@keyframes fadeup{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes slideup{from{opacity:0;transform:translateY(100%)}to{opacity:1;transform:none}}

/* CATEGORY CARDS */
.cats{background:#000;display:flex;flex-direction:column}
.cat-card{position:relative;width:100%;height:100svh;min-height:580px;overflow:hidden;display:block;text-decoration:none;border-top:1px solid rgba(255,255,255,.1)}
.cat-card:first-child{border-top:none}
.cat-card.loafer{background:#0C2118}
.cat-card.oxford{background:#141410}
.cat-card.flex{background:#0A1B12}
.cat-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;display:block}
.cat-art{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:1;pointer-events:none;overflow:hidden}
.cat-art svg{width:110%;max-width:500px;opacity:.06;animation:breathe 16s ease-in-out infinite alternate}
.cat-card:nth-child(2) .cat-art svg{animation-delay:-6s}
.cat-card:nth-child(3) .cat-art svg{animation-delay:-11s}
@keyframes breathe{0%{transform:scale(1)}100%{transform:scale(1.09) translateY(-18px)}}
.cat-grad{position:absolute;inset:0;z-index:2;background:linear-gradient(to top,rgba(0,0,0,.93) 0%,rgba(0,0,0,.48) 30%,rgba(0,0,0,.12) 65%,rgba(0,0,0,0) 100%)}
.cat-ghost-num{position:absolute;top:28px;right:16px;font-family:var(--f);font-size:clamp(80px,26vw,140px);font-weight:300;color:rgba(255,255,255,.03);line-height:1;z-index:3;user-select:none}
.cat-content{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:0 28px calc(52px + env(safe-area-inset-bottom))}
.cat-tag{font-size:7px;font-weight:400;letter-spacing:.55em;text-transform:uppercase;color:rgba(184,146,74,.45);margin-bottom:14px;display:block;overflow:hidden}
.cat-tag-inner{display:block;transform:translateY(100%);opacity:0;transition:transform .9s var(--ease),opacity .9s var(--ease)}
.cat-name-wrap{overflow:hidden;margin-bottom:12px}
.cat-name{font-family:var(--f);font-size:clamp(44px,13vw,66px);font-weight:300;color:#fff;line-height:.9;display:block;transform:translateY(105%);opacity:0;transition:transform 1s var(--ease) .08s,opacity 1s var(--ease) .08s}
.cat-desc{font-size:10px;font-weight:300;color:rgba(255,255,255,.32);letter-spacing:.03em;line-height:1.75;margin-bottom:22px;max-width:260px;opacity:0;transform:translateY(14px);transition:opacity .9s var(--ease) .18s,transform .9s var(--ease) .18s}
.cat-link{display:inline-flex;align-items:center;gap:12px;font-size:8px;font-weight:400;letter-spacing:.42em;text-transform:uppercase;color:rgba(255,255,255,.45);opacity:0;transform:translateY(10px);transition:opacity .9s var(--ease) .28s,transform .9s var(--ease) .28s}
.cat-link-line{width:0;height:1px;background:rgba(255,255,255,.35);display:block;transition:width .7s var(--ease) .6s}
.cat-card.visible .cat-tag-inner{transform:none;opacity:1}
.cat-card.visible .cat-name{transform:none;opacity:1}
.cat-card.visible .cat-desc{opacity:1;transform:none}
.cat-card.visible .cat-link{opacity:1;transform:none}
.cat-card.visible .cat-link-line{width:28px}

/* PRODUCTS */
.col{background:var(--page);padding:64px 0 72px}
.sec-hd{padding:0 28px;margin-bottom:40px}
.sec-ey{display:block;font-size:8px;font-weight:400;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.sec-h2{font-family:var(--f);font-size:clamp(32px,9vw,46px);font-weight:300;color:var(--ink);line-height:1.05}
.sec-h2 em{color:var(--green);font-style:italic}
.bblock{margin-bottom:52px}
.bblock:last-child{margin-bottom:0}
.brow-hd{display:flex;align-items:center;gap:14px;padding:0 28px;margin-bottom:20px}
.brow-name{font-family:var(--f);font-size:16px;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:var(--ink);white-space:nowrap}
.brow-rule{flex:1;height:1px;background:rgba(17,17,17,.08)}
.brow-link{font-size:8px;font-weight:400;letter-spacing:.28em;text-transform:uppercase;color:var(--green);white-space:nowrap}
.card-row{display:flex;gap:10px;overflow-x:auto;padding:0 28px 2px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.card-row::-webkit-scrollbar{display:none}
.pcard{flex-shrink:0;width:56vw;max-width:190px;scroll-snap-align:start}
.pcard-img{width:100%;aspect-ratio:3/4;position:relative;overflow:hidden;margin-bottom:10px;background:#0D2B1F}
.pcard-img img{width:100%;height:100%;object-fit:cover;display:block}
.ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center}
.g1{background:var(--green)}.g2{background:#0B2419}.g3{background:#102C20}
.g4{background:#091E15}.g5{background:#0E2820}.g6{background:#0C2218}
.g7{background:#0A1F17}.g8{background:#0D2620}.g9{background:#112B1E}
.ph svg{width:72%;opacity:.15}
.ph-tag{position:absolute;bottom:8px;left:8px;font-size:7px;letter-spacing:.25em;text-transform:uppercase;color:rgba(184,146,74,.6)}
.ph-badge{position:absolute;top:8px;right:8px;background:var(--gold);color:#fff;font-size:6px;letter-spacing:.15em;text-transform:uppercase;padding:3px 6px}
.pcard-brand{font-size:7px;font-weight:400;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.pcard-name{font-family:var(--f);font-size:15px;font-weight:300;color:var(--ink);line-height:1.2;margin-bottom:4px}
.pcard-note{font-size:9px;font-weight:300;color:var(--mid);line-height:1.5;margin-bottom:7px}
.pcard-price{font-family:var(--f);font-size:14px;font-weight:500;color:var(--ink)}

/* OUR FAVOURITE */
.phil{background:var(--green);padding:72px 28px;position:relative;overflow:hidden}
.phil::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 100%,rgba(184,146,74,.06),transparent 70%);pointer-events:none}
.phil .sec-ey{color:rgba(184,146,74,.55)}
.phil .sec-h2{color:#fff}
.phil .sec-h2 em{color:var(--gold2);font-style:italic}
.phil-body{font-family:var(--f);font-style:italic;font-size:16px;font-weight:300;line-height:2;color:rgba(255,255,255,.4);margin:24px 0 44px}
.phil-rows{border-top:1px solid rgba(255,255,255,.08)}
.prow{display:grid;grid-template-columns:40px 1fr;gap:0 16px;padding:24px 0;border-bottom:1px solid rgba(255,255,255,.06);opacity:0;transform:translateX(-10px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.prow.in{opacity:1;transform:none}
.pn{font-family:var(--f);font-size:26px;font-weight:300;color:rgba(184,146,74,.28);line-height:1;padding-top:4px}
.prow h4{font-size:9px;font-weight:500;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:6px}
.prow p{font-size:12px;font-weight:300;line-height:1.8;color:rgba(255,255,255,.3)}

/* CTA */
.cta{background:var(--page);padding:72px 28px;border-top:1px solid rgba(17,17,17,.06)}
.cta h2{font-family:var(--f);font-size:clamp(32px,9vw,48px);font-weight:300;color:var(--ink);line-height:1.1}
.cta h2 em{color:var(--green);font-style:italic}
.cta-sub{font-family:var(--f);font-style:italic;font-size:14px;font-weight:300;color:var(--mid);line-height:1.8;margin:14px 0 36px}
.cta-btns{display:flex;flex-direction:column;align-items:flex-start;gap:12px}
.btn-g{display:inline-flex;align-items:center;gap:12px;background:#06C755;color:#fff;font-family:var(--f);font-size:9px;font-weight:500;letter-spacing:.3em;text-transform:uppercase;padding:16px 32px;min-height:50px}
.btn-p{display:inline-flex;align-items:center;gap:12px;background:var(--green);color:#fff;font-family:var(--f);font-size:9px;font-weight:500;letter-spacing:.3em;text-transform:uppercase;padding:16px 32px;min-height:50px}
.lico{width:18px;height:18px;flex-shrink:0}

/* FOOTER */
footer{background:var(--green);padding:52px 28px calc(44px + env(safe-area-inset-bottom))}
.ft{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:36px;padding-bottom:32px;border-bottom:1px solid rgba(255,255,255,.08)}
.ft-logo img{height:32px;width:auto;filter:brightness(0) invert(1);opacity:.7}
.ftg{font-size:8px;font-weight:300;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.22);margin-top:6px}
.fa{text-align:right}
.fa p{font-size:9px;font-weight:300;color:rgba(255,255,255,.3);line-height:1.9}
.fa strong{color:rgba(255,255,255,.55);font-weight:400}
.fb2{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:24px}
.fb2 a{font-size:11px;font-weight:300;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.28)}
.fn{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:28px}
.fn a{font-size:8px;font-weight:300;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.18)}
.fcp{font-size:7px;letter-spacing:.1em;color:rgba(255,255,255,.11)}
.fv{font-size:6px;color:rgba(184,146,74,.14);margin-top:4px}

/* ============ DESKTOP ============ */
@media(min-width:768px){
  /* Nav desktop */
  .nav{height:calc(72px + env(safe-area-inset-top));padding:env(safe-area-inset-top) 48px 0}
  .nav-logo img{height:42px}
  .nav-shop{display:block}
  .nav-burger{display:none}

  /* Hero desktop */
  .hero-body{padding:0 72px calc(80px + env(safe-area-inset-bottom));max-width:560px}
  .hero-eyebrow{font-size:9px}
  .hero-title{font-size:clamp(52px,6vw,80px)}
  .hero-sub{font-size:12px;max-width:320px}
  .hero-cta{font-size:9px}

  /* Category cards — side by side on desktop */
  .cats{flex-direction:row;height:90vh;min-height:560px}
  .cat-card{width:33.333%;height:100%;border-top:none;border-left:1px solid rgba(255,255,255,.1)}
  .cat-card:first-child{border-left:none}
  .cat-ghost-num{font-size:clamp(60px,8vw,100px);top:24px;right:20px}
  .cat-content{padding:0 32px 40px}
  .cat-name{font-size:clamp(36px,4vw,54px)}
  .cat-desc{font-size:11px;max-width:220px}

  /* Products desktop — grid */
  .col{padding:80px 0 96px}
  .sec-hd{padding:0 48px;margin-bottom:48px}
  .brow-hd{padding:0 48px}
  .card-row{padding:0 48px 4px;gap:16px}
  .pcard{width:22vw;max-width:240px}

  /* Phil desktop */
  .phil{padding:96px 48px;display:grid;grid-template-columns:1fr 1fr;gap:0 64px;align-items:start}
  .phil-hd{grid-column:1;grid-row:1 / 3}
  .phil .sec-ey{display:block}
  .phil .sec-h2{font-size:clamp(40px,5vw,56px)}
  .phil-body{font-size:18px;margin-top:24px;margin-bottom:0;grid-column:1}
  .phil-rows{grid-column:2;grid-row:1 / 4;border-top:1px solid rgba(255,255,255,.08);margin-top:0;align-self:start}

  /* CTA desktop */
  .cta{padding:96px 48px;display:grid;grid-template-columns:1fr 1fr;gap:0 64px;align-items:center}
  .cta-btns{flex-direction:row}

  /* Footer desktop */
  footer{padding:64px 48px calc(52px + env(safe-area-inset-bottom))}
  .ft{margin-bottom:48px}
  .fb2{gap:28px}
  .fn{gap:24px}
}
</style>
</head>
<body>

<nav class="nav h" id="nav">
  <a href="https://curatedandcobkk.com" class="nav-logo">
    <img src={logo} alt="Curated & Co."/>
  </a>
  <div class="nav-right">
    <a href="https://curatedandcobkk.com" class="nav-shop">Shop All</a>
    <div class="nav-burger"><span></span><span></span></div>
  </div>
</nav>

<div class="hero" id="hero">
  <div class="hero-media">
    {heroVideo && <video autoplay muted loop playsinline src={heroVideo}></video>}
    {!heroVideo && heroImage && <img src={heroImage} alt="Curated & Co."/>}
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-body">
    <div class="hero-eyebrow">{heroEyebrow}</div>
    <div class="hero-title-wrap">
      <div class="hero-title">{heroLine1}<br/><em>{heroLine2}</em></div>
    </div>
    <div class="hero-sub">{heroSub}</div>
    <a href={heroCtaUrl} class="hero-cta">{heroCta}</a>
  </div>
</div>

<div class="cats">
  <a href={cat1.url} class="cat-card loafer">
    {cat1.photo && <img class="cat-photo" src={cat1.photo} alt={cat1.name1}/>}
    <div class="cat-art" style={cat1.photo ? "opacity:0" : ""}><svg viewBox="0 0 560 280" fill="none"><path d="M48 198C82 138 164 106 254 100C310 96 366 104 412 124C458 144 500 172 514 190C526 204 520 220 500 226C462 237 380 240 272 238C182 236 100 232 68 222C48 216 36 212 48 198Z" fill="#C9A96E"/><rect x="210" y="72" width="140" height="28" rx="14" fill="#C9A96E" opacity="0.6"/></svg></div>
    <div class="cat-grad"></div>
    <div class="cat-ghost-num">01</div>
    <div class="cat-content">
      <span class="cat-tag"><span class="cat-tag-inner">{cat1.tag}</span></span>
      <div class="cat-name-wrap"><span class="cat-name">{cat1.name1}<br/>{cat1.name2}</span></div>
      <div class="cat-desc">{cat1.desc}</div>
      <div class="cat-link">Shop the Collection<span class="cat-link-line"></span></div>
    </div>
  </a>

  <a href={cat2.url} class="cat-card oxford">
    {cat2.photo && <img class="cat-photo" src={cat2.photo} alt={cat2.name1}/>}
    <div class="cat-art" style={cat2.photo ? "opacity:0" : ""}><svg viewBox="0 0 560 280" fill="none"><path d="M52 200C86 140 168 108 258 102C314 98 368 106 414 126C460 146 500 174 514 192C524 206 518 222 498 228C460 239 376 242 268 240C178 238 96 234 64 224C44 218 40 214 52 200Z" fill="#C9A96E"/><path d="M258 102C262 76 266 52 270 38C274 24 282 17 292 21C304 26 306 46 302 68" stroke="#C9A96E" stroke-width="7" stroke-linecap="round" fill="none"/></svg></div>
    <div class="cat-grad"></div>
    <div class="cat-ghost-num">02</div>
    <div class="cat-content">
      <span class="cat-tag"><span class="cat-tag-inner">{cat2.tag}</span></span>
      <div class="cat-name-wrap"><span class="cat-name">{cat2.name1}<br/>{cat2.name2}</span></div>
      <div class="cat-desc">{cat2.desc}</div>
      <div class="cat-link">Shop the Collection<span class="cat-link-line"></span></div>
    </div>
  </a>

