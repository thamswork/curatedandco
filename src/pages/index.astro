---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<title>Curated & Co. Bangkok</title>
<meta name="description" content="Curated and Co. Bangkok — curator of shoemaking heritage. Berwick 1707, Carmina, Paraboot."/>
<style>
@font-face{font-family:'K2D';src:url('/fonts/K2D-Light.ttf') format('truetype');font-weight:300;font-style:normal;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-LightItalic.ttf') format('truetype');font-weight:300;font-style:italic;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-Regular.ttf') format('truetype');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-Italic.ttf') format('truetype');font-weight:400;font-style:italic;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-Medium.ttf') format('truetype');font-weight:500;font-style:normal;font-display:swap}
@font-face{font-family:'K2D';src:url('/fonts/K2D-SemiBold.ttf') format('truetype');font-weight:600;font-style:normal;font-display:swap}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
:root{
  --green:#0D2B1F;--gold:#B8924A;--gold2:#CFA55A;
  --cream:#F7F4EF;--page:#FAFAF8;--ink:#111;--mid:#666;
  --ease:cubic-bezier(0.16,1,0.3,1);
  --f:'K2D',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{background:#000;color:var(--ink);font-family:var(--f);font-weight:300;overflow-x:hidden;-webkit-font-smoothing:antialiased}
.rv{opacity:0;transform:translateY(20px);transition:opacity 1s var(--ease),transform 1s var(--ease)}
.rv.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* NAV */
.nav{position:fixed;inset:0 0 auto 0;z-index:300;height:calc(64px + env(safe-area-inset-top));padding:env(safe-area-inset-top) 20px 0;display:flex;align-items:center;justify-content:space-between;transition:background .5s var(--ease),border-color .5s var(--ease)}
.nav.h{background:linear-gradient(to bottom,rgba(0,0,0,.55),transparent);border-bottom:1px solid transparent}
.nav.l{background:#fff;border-bottom:1px solid rgba(0,0,0,.08)}
.nav-logo img{height:36px;width:auto;transition:filter .4s}
.nav.h .nav-logo img{filter:brightness(0) invert(1)}
.nav.l .nav-logo img{filter:none}

/* Desktop center nav */
.nav-links{display:none;align-items:center;gap:0;position:absolute;left:50%;transform:translateX(-50%)}
.nav-links a{font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;padding:0 14px;white-space:nowrap;transition:color .3s}
.nav.h .nav-links a{color:rgba(255,255,255,.65)}
.nav.l .nav-links a{color:var(--green)}
.nav.h .nav-links a:hover{color:#fff}
.nav.l .nav-links a:hover{color:var(--gold)}

/* Desktop right icons */
.nav-icons{display:none;align-items:center;gap:16px}
.nav-icons a{transition:opacity .3s}
.nav-icons a:hover{opacity:.6}
.nav-icons svg{width:18px;height:18px}
.nav.h .nav-icons svg{stroke:#fff;fill:none}
.nav.l .nav-icons svg{stroke:var(--green);fill:none}

/* Mobile right */
.nav-right{display:flex;align-items:center;gap:14px}
.nav-burger{display:flex;flex-direction:column;gap:5px;align-items:center;justify-content:center;width:44px;height:44px;cursor:pointer;position:relative;z-index:400}
.nav-burger span{display:block;width:22px;height:1px;transition:all .4s var(--ease);transform-origin:center}
.nav-burger span:nth-child(2){width:14px;align-self:flex-end}
.nav.h .nav-burger span{background:rgba(255,255,255,.8)}
.nav.l .nav-burger span{background:var(--green)}
.nav-burger.open span:nth-child(1){transform:translateY(6px) rotate(45deg);background:var(--ink)!important}
.nav-burger.open span:nth-child(2){opacity:0;width:0}
.nav-burger.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg);background:var(--ink)!important}

/* MOBILE MENU DRAWER */
.nav-drawer{position:fixed;inset:0;z-index:350;pointer-events:none}
.nav-drawer-bg{position:absolute;inset:0;background:rgba(0,0,0,.5);opacity:0;transition:opacity .4s var(--ease)}
.nav-drawer-panel{position:absolute;top:0;right:0;bottom:0;width:min(320px,85vw);background:#fff;transform:translateX(100%);transition:transform .5s var(--ease);display:flex;flex-direction:column;padding:calc(80px + env(safe-area-inset-top)) 32px 48px;gap:0}
.nav-drawer.open{pointer-events:all}
.nav-drawer.open .nav-drawer-bg{opacity:1}
.nav-drawer.open .nav-drawer-panel{transform:none}
.drawer-link{display:block;font-size:13px;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--ink);padding:16px 0;border-bottom:1px solid rgba(0,0,0,.06);transition:color .2s}
.drawer-link:hover{color:var(--gold)}
.drawer-link:last-of-type{border-bottom:none}
.drawer-icons{display:flex;gap:20px;margin-top:36px;padding-top:24px;border-top:1px solid rgba(0,0,0,.06)}
.drawer-icons a svg{width:20px;height:20px;stroke:var(--green);fill:none}
.drawer-logo{margin-top:auto;opacity:.12}
.drawer-logo img{height:32px}

/* HERO */
.hero{position:relative;height:100svh;min-height:600px;overflow:hidden;background:#0a0a0a}
.hero-media{position:absolute;inset:0;z-index:1}
.hero-media video,.hero-media img{width:100%;height:100%;object-fit:cover}
.hero-overlay{position:absolute;inset:0;z-index:2;background:linear-gradient(to top,rgba(0,0,0,.78) 0%,rgba(0,0,0,.15) 50%,rgba(0,0,0,.04) 100%)}
.hero-body{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:0 24px calc(64px + env(safe-area-inset-bottom))}
.hero-eyebrow{font-size:8px;letter-spacing:.6em;text-transform:uppercase;color:rgba(255,255,255,.32);margin-bottom:12px;opacity:0;animation:fadeup .9s var(--ease) .3s forwards}
.hero-title-wrap{overflow:hidden;margin-bottom:8px}
.hero-title{font-size:clamp(32px,9vw,52px);font-weight:300;color:rgba(255,255,255,.78);line-height:.95;opacity:0;transform:translateY(100%);animation:slideup 1s var(--ease) .5s forwards}
.hero-title em{font-style:italic;color:rgba(184,146,74,.7)}
.hero-sub{font-size:10px;color:rgba(255,255,255,.28);letter-spacing:.04em;line-height:1.8;margin-bottom:28px;max-width:220px;opacity:0;animation:fadeup .9s var(--ease) .75s forwards}
.hero-cta{display:inline-flex;align-items:center;gap:10px;font-size:8px;letter-spacing:.42em;text-transform:uppercase;color:rgba(255,255,255,.4);opacity:0;animation:fadeup .9s var(--ease) .95s forwards}
.hero-cta::after{content:'';width:22px;height:1px;background:rgba(255,255,255,.28);display:block}
@keyframes fadeup{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes slideup{from{opacity:0;transform:translateY(100%)}to{opacity:1;transform:none}}

/* CATEGORY CARDS */
.cats{background:#000;display:flex;flex-direction:column}
.cat-card{position:relative;width:100%;height:100svh;min-height:560px;overflow:hidden;display:block;text-decoration:none;border-top:1px solid rgba(255,255,255,.1)}
.cat-card:first-child{border-top:none}
.cat-card.loafer{background:#0C2118}
.cat-card.oxford{background:#141410}
.cat-card.flex{background:#0A1B12}
.cat-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1}
.cat-art{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:1;pointer-events:none}
.cat-art svg{width:110%;max-width:500px;opacity:.06;animation:breathe 16s ease-in-out infinite alternate}
.cat-card:nth-child(2) .cat-art svg{animation-delay:-6s}
.cat-card:nth-child(3) .cat-art svg{animation-delay:-11s}
@keyframes breathe{0%{transform:scale(1)}100%{transform:scale(1.09) translateY(-18px)}}
.cat-grad{position:absolute;inset:0;z-index:2;background:linear-gradient(to top,rgba(0,0,0,.92) 0%,rgba(0,0,0,.45) 30%,rgba(0,0,0,.1) 65%,rgba(0,0,0,0) 100%)}
.cat-ghost-num{position:absolute;top:28px;right:16px;font-size:clamp(80px,26vw,140px);font-weight:300;color:rgba(255,255,255,.03);line-height:1;z-index:3;user-select:none}
.cat-content{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:0 24px calc(48px + env(safe-area-inset-bottom))}
.cat-tag{font-size:7px;letter-spacing:.55em;text-transform:uppercase;color:rgba(184,146,74,.45);margin-bottom:14px;display:block;overflow:hidden}
.cat-tag-inner{display:block;transform:translateY(100%);opacity:0;transition:transform .9s var(--ease),opacity .9s var(--ease)}
.cat-name-wrap{overflow:hidden;margin-bottom:12px}
.cat-name{font-size:clamp(44px,13vw,66px);font-weight:300;color:#fff;line-height:.9;display:block;transform:translateY(105%);opacity:0;transition:transform 1s var(--ease) .08s,opacity 1s var(--ease) .08s}
.cat-desc{font-size:10px;color:rgba(255,255,255,.32);line-height:1.75;margin-bottom:22px;max-width:260px;opacity:0;transform:translateY(14px);transition:opacity .9s var(--ease) .18s,transform .9s var(--ease) .18s}
.cat-link{display:inline-flex;align-items:center;gap:12px;font-size:7px;letter-spacing:.48em;text-transform:uppercase;color:rgba(255,255,255,.45);opacity:0;transform:translateY(10px);transition:opacity .9s var(--ease) .28s,transform .9s var(--ease) .28s}
.cat-link-line{width:0;height:1px;background:rgba(255,255,255,.35);display:block;transition:width .7s var(--ease) .6s}
.cat-card.visible .cat-tag-inner{transform:none;opacity:1}
.cat-card.visible .cat-name{transform:none;opacity:1}
.cat-card.visible .cat-desc{opacity:1;transform:none}
.cat-card.visible .cat-link{opacity:1;transform:none}
.cat-card.visible .cat-link-line{width:28px}

/* PRODUCTS — 2 col grid like WordPress */
.prods{background:var(--page);padding:64px 0 72px}
.sec-hd{padding:0 20px;margin-bottom:36px}
.sec-ey{display:block;font-size:8px;font-weight:400;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.sec-h2{font-size:clamp(28px,8vw,42px);font-weight:300;color:var(--ink);line-height:1.05}
.sec-h2 em{color:var(--green);font-style:italic}
.prod-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(0,0,0,.06)}
.prod-item{background:var(--page);text-decoration:none;display:block}
.prod-img{width:100%;aspect-ratio:1/1;background:#f0ede8;position:relative;overflow:hidden}
.prod-img img{width:100%;height:100%;object-fit:cover}
.prod-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f0ede8}
.prod-ph svg{width:60%;opacity:.12}
.prod-info{padding:12px 14px 18px}
.prod-brand{font-size:7px;font-weight:500;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
.prod-name{font-size:13px;font-weight:400;color:var(--ink);line-height:1.3;margin-bottom:3px}
.prod-note{font-size:9px;color:var(--mid);margin-bottom:6px}
.prod-price{font-size:14px;font-weight:500;color:var(--ink)}
.prod-more{display:block;text-align:center;padding:20px;font-size:9px;font-weight:400;letter-spacing:.3em;text-transform:uppercase;color:var(--green);border-top:1px solid rgba(0,0,0,.06)}

/* LOOKS — editorial slider */
.looks-sec{background:#000;padding:0;overflow:hidden}
.looks-hd{padding:52px 20px 32px}
.looks-hd .sec-ey{color:rgba(184,146,74,.6)}
.looks-hd .sec-h2{color:#fff}
.looks-hd .sec-h2 em{color:var(--gold2);font-style:italic}
.looks-reel{display:flex;gap:3px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding-bottom:3px}
.looks-reel::-webkit-scrollbar{display:none}
.looks-item{flex-shrink:0;width:78vw;max-width:340px;aspect-ratio:3/4;scroll-snap-align:start;position:relative;overflow:hidden;background:#111}
.looks-item img{width:100%;height:100%;object-fit:cover;transition:transform .6s var(--ease)}
.looks-item:active img{transform:scale(1.03)}
.looks-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#111}
.looks-ph-icon{font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.2)}
.looks-caption{position:absolute;bottom:0;left:0;right:0;padding:16px;background:linear-gradient(to top,rgba(0,0,0,.7),transparent);font-size:9px;letter-spacing:.08em;color:rgba(255,255,255,.6);opacity:0;transition:opacity .3s}
.looks-item:hover .looks-caption{opacity:1}
.looks-footer{padding:20px 20px 52px;display:flex;align-items:center;justify-content:space-between}
.looks-count{font-size:8px;letter-spacing:.3em;color:rgba(255,255,255,.3);text-transform:uppercase}
.looks-ig{display:inline-flex;align-items:center;gap:10px;font-size:8px;letter-spacing:.35em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.looks-ig::after{content:'';width:20px;height:1px;background:rgba(255,255,255,.3);display:block}

/* JOURNAL */
/* JOURNAL — full width editorial */
.journal-sec{background:#fff;padding:72px 0 80px}
.journal-sec .sec-hd{padding:0 24px;margin-bottom:52px}
.journal-sec .sec-h2 em{color:var(--green)}
.journal-list{display:flex;flex-direction:column;gap:0}
.journal-item{display:block;text-decoration:none;overflow:hidden;border-bottom:1px solid rgba(0,0,0,.07);padding-bottom:56px;margin-bottom:56px}
.journal-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.journal-img-wrap{width:100%;aspect-ratio:16/10;overflow:hidden;position:relative;background:#ede9e3;margin-bottom:24px}
.journal-img-wrap img{width:100%;height:110%;object-fit:cover;object-position:center;transform:translateY(0);transition:transform .1s linear;will-change:transform}
.journal-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#ede9e3}
.journal-ph-svg{width:55%;opacity:.14}
.journal-body{padding:0 24px}
.journal-tag{font-size:7px;font-weight:500;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:block;opacity:0;transform:translateY(12px);transition:opacity .8s var(--ease),transform .8s var(--ease)}
.journal-title{font-size:clamp(22px,6vw,32px);font-weight:300;color:var(--ink);line-height:1.15;margin-bottom:14px;opacity:0;transform:translateY(16px);transition:opacity .9s var(--ease) .08s,transform .9s var(--ease) .08s}
.journal-excerpt{font-size:12px;color:var(--mid);line-height:1.8;margin-bottom:20px;opacity:0;transform:translateY(12px);transition:opacity .9s var(--ease) .16s,transform .9s var(--ease) .16s}
.journal-read{display:inline-flex;align-items:center;gap:10px;font-size:8px;letter-spacing:.4em;text-transform:uppercase;color:var(--green);opacity:0;transform:translateY(10px);transition:opacity .9s var(--ease) .24s,transform .9s var(--ease) .24s}
.journal-read::after{content:'';width:0;height:1px;background:var(--green);display:block;transition:width .6s var(--ease) .5s}
.journal-item.visible .journal-tag{opacity:1;transform:none}
.journal-item.visible .journal-title{opacity:1;transform:none}
.journal-item.visible .journal-excerpt{opacity:1;transform:none}
.journal-item.visible .journal-read{opacity:1;transform:none}
.journal-item.visible .journal-read::after{width:24px}
.journal-more{display:flex;align-items:center;justify-content:center;gap:12px;padding:32px 24px 0;font-size:9px;letter-spacing:.4em;text-transform:uppercase;color:var(--green)}
.journal-more::after{content:'';width:24px;height:1px;background:var(--green);display:block}

/* OUR FAVOURITE */
.phil{background:var(--green);padding:68px 24px;position:relative;overflow:hidden}
.phil::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 100%,rgba(184,146,74,.06),transparent 70%);pointer-events:none}
.phil .sec-ey{color:rgba(184,146,74,.55)}
.phil .sec-h2{color:#fff}
.phil .sec-h2 em{color:var(--gold2);font-style:italic}
.phil-body{font-style:italic;font-size:15px;line-height:2;color:rgba(255,255,255,.38);margin:20px 0 40px}
.phil-rows{border-top:1px solid rgba(255,255,255,.08)}
.prow{display:grid;grid-template-columns:36px 1fr;gap:0 16px;padding:22px 0;border-bottom:1px solid rgba(255,255,255,.06);opacity:0;transform:translateX(-10px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.prow.in{opacity:1;transform:none}
.pn{font-size:24px;font-weight:300;color:rgba(184,146,74,.28);line-height:1;padding-top:4px}
.prow h4{font-size:8px;font-weight:500;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:5px}
.prow p{font-size:11px;line-height:1.8;color:rgba(255,255,255,.3)}

/* INSTAGRAM */
.ig-sec{background:#fff;padding:52px 0}
.ig-sec .sec-hd{padding:0 20px;margin-bottom:28px}
.ig-sec .sec-ey{color:var(--gold)}
.ig-sec .sec-h2{color:var(--ink)}
.ig-sec .sec-h2 em{color:var(--green)}
.ig-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.ig-cell{aspect-ratio:1/1;background:#f0ede8;overflow:hidden;position:relative}
.ig-cell img{width:100%;height:100%;object-fit:cover;transition:transform .4s var(--ease)}
.ig-follow{display:flex;align-items:center;justify-content:center;padding:24px;border-top:1px solid rgba(0,0,0,.06)}
.ig-follow a{display:inline-flex;align-items:center;gap:10px;font-size:9px;font-weight:400;letter-spacing:.3em;text-transform:uppercase;color:var(--green)}
.ig-follow a::after{content:'';width:20px;height:1px;background:var(--green);display:block}

/* VISIT CTA */
.cta{background:var(--page);padding:64px 24px;border-top:1px solid rgba(0,0,0,.06)}
.cta h2{font-size:clamp(28px,8vw,44px);font-weight:300;color:var(--ink);line-height:1.1;margin-bottom:6px}
.cta h2 em{color:var(--green);font-style:italic}
.cta-sub{font-style:italic;font-size:13px;color:var(--mid);line-height:1.8;margin:12px 0 32px}
.cta-btns{display:flex;flex-direction:column;gap:10px;align-items:flex-start}
.btn-g{display:inline-flex;align-items:center;gap:10px;background:#06C755;color:#fff;font-size:9px;font-weight:500;letter-spacing:.28em;text-transform:uppercase;padding:15px 28px;min-height:48px}
.btn-map{display:inline-flex;align-items:center;gap:10px;border:1px solid rgba(13,43,31,.25);color:var(--green);font-size:9px;font-weight:400;letter-spacing:.28em;text-transform:uppercase;padding:15px 28px;min-height:48px}
.lico{width:17px;height:17px;flex-shrink:0}

/* FOOTER */
footer{background:var(--green);padding:48px 24px calc(40px + env(safe-area-inset-bottom))}
.ft{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:32px;padding-bottom:28px;border-bottom:1px solid rgba(255,255,255,.08)}
.ft-logo img{height:40px;filter:brightness(0) invert(1);opacity:.75}
.ftg{font-size:7px;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.22);margin-top:6px}
.fa{text-align:right}
.fa p{font-size:9px;color:rgba(255,255,255,.3);line-height:1.9}
.fa strong{color:rgba(255,255,255,.55);font-weight:500}
.fb2{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:20px}
.fb2 a{font-size:10px;font-weight:300;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.26)}
.fn{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:24px}
.fn a{font-size:8px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.18)}
.fcp{font-size:7px;color:rgba(255,255,255,.1)}

/* DESKTOP */
@media(min-width:768px){
  /* NAV DESKTOP */
  .nav{height:calc(72px + env(safe-area-inset-top));padding-left:48px;padding-right:48px}
  .nav-logo img{height:40px}
  .nav-links{display:flex}
  .nav-icons{display:flex}
  .nav-right{display:none}

  /* HERO */
  .hero-body{padding:0 80px calc(88px + env(safe-area-inset-bottom));max-width:640px}
  .hero-title{font-size:clamp(48px,5.5vw,72px)}
  .hero-sub{font-size:12px;max-width:340px}

  /* CATEGORY — 3 side by side */
  .cats{flex-direction:row;height:88vh;min-height:580px}
  .cat-card{width:33.333%;height:100%;border-top:none;border-left:1px solid rgba(255,255,255,.1)}
  .cat-card:first-child{border-left:none}
  .cat-name{font-size:clamp(34px,3.5vw,48px)}
  .cat-content{padding:0 32px 40px}
  .cat-desc{font-size:11px;max-width:200px}

  /* PRODUCTS — 4 col */
  .prods{padding:88px 0 96px}
  .sec-hd{padding:0 56px;margin-bottom:48px}
  .prod-grid{grid-template-columns:repeat(4,1fr)}
  .prod-info{padding:14px 16px 20px}
  .prod-name{font-size:14px}

  /* LOOKS */
  .looks-hd{padding:72px 56px 40px}
  .looks-item{width:38vw;max-width:480px}
  .looks-footer{padding:24px 56px 64px}

  /* JOURNAL — 3 col grid on desktop, not full width stacked */
  .journal-sec{padding:88px 0 96px}
  .journal-sec .sec-hd{padding:0 56px;margin-bottom:52px}
  .journal-list{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:32px;
    padding:0 56px;
  }
  .journal-item{
    border-bottom:none;
    padding-bottom:0;
    margin-bottom:0;
    display:flex;
    flex-direction:column;
    border-right:1px solid rgba(0,0,0,.07);
    padding-right:32px;
  }
  .journal-item:last-child{border-right:none;padding-right:0}
  .journal-img-wrap{aspect-ratio:4/3;margin-bottom:20px}
  .journal-body{padding:0}
  .journal-title{font-size:18px;font-weight:400;line-height:1.3}
  .journal-excerpt{font-size:11px;-webkit-line-clamp:3}
  .journal-more{padding:40px 56px 0;justify-content:flex-start}

  /* OUR FAVOURITE — 2 col */
  .phil{padding:96px 56px;display:grid;grid-template-columns:1fr 1fr;gap:0 72px;align-items:start}
  .phil-rows{margin-top:0}
  .phil-body{font-size:17px}

  /* INSTAGRAM — 4 col */
  .ig-sec{padding:72px 0}
  .ig-sec .sec-hd{padding:0 56px;margin-bottom:36px}
  .ig-grid{grid-template-columns:repeat(4,1fr)}
  .ig-follow{padding:28px 56px}

  /* CTA */
  .cta{padding:88px 56px;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
  .cta-btns{flex-direction:row;flex-wrap:wrap}

  /* FOOTER */
  footer{padding:64px 56px calc(52px + env(safe-area-inset-bottom))}
  .fb2{gap:24px}
  .fn{gap:20px}
}
</style>
</head>
<body>

<nav class="nav h" id="nav">
