      </a>
    ))}
  </div>
  <a href="https://curatedandcobkk.com/shop/" class="prod-more rv">View All Products →</a>
</section>

<!-- LOOKS -->
<section class="looks-sec">
  <div class="looks-hd">
    <span class="sec-ey rv">Editorial</span>
    <h2 class="sec-h2 rv d1">Looks<br/><em>& Style</em></h2>
