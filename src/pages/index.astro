---
const heroImage = "https://res.cloudinary.com/dynjnftnu/image/upload/v1777049840/Oxfords_hkfvai.jpg";
const heroVideo = "https://res.cloudinary.com/dynjnftnu/video/upload/v1777050102/Landing_-_V_kll7wf.mp4";
const brandStory = "Berwick 1707 represents the pinnacle of Spanish shoemaking tradition. Every pair is crafted by hand at the Berwick artisan floor in Almansa, using the finest leathers and time-honoured Goodyear welt construction.";
const ctaText = "Shop the Collection";
const ctaUrl = "https://curatedandcobkk.com/product-category/brands/berwick/";
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<title>Curated & Co. Bangkok</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
a{color:inherit;text-decoration:none}
:root{
  --green:#0D2B1F;--gold:#B8924A;--gold2:#CFA55A;
  --cream:#F7F4EF;--page:#FAFAF8;--ink:#111;--mid:#5A5A58;
  --ease:cubic-bezier(0.16,1,0.3,1);
  --fd:'Cormorant Garamond',Georgia,serif;
  --fb:'Jost',sans-serif;
}
html{scroll-behavior:smooth}
body{background:#000;color:var(--ink);font-family:var(--fb);font-weight:300;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* scroll reveal */
.rv{opacity:0;transform:translateY(20px);transition:opacity 1.1s var(--ease),transform 1.1s var(--ease)}
.rv.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.22s}.d3{transition-delay:.34s}

/* NAV */
.nav{position:fixed;inset:0 0 auto 0;z-index:300;height:calc(58px + env(safe-area-inset-top));padding:env(safe-area-inset-top) 20px 0;display:flex;align-items:center;justify-content:space-between;transition:all .5s var(--ease)}
.nav.h{background:linear-gradient(to bottom,rgba(0,0,0,.5),transparent)}
.nav.l{background:var(--page);border-bottom:1px solid rgba(17,17,17,.07)}
.nav-logo{display:flex;align-items:center;gap:9px}
.nav-c{width:28px;height:28px;border-radius:50%;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:12px;font-weight:300;transition:color .4s}
.nav-wm{font-family:var(--fb);font-size:9px;font-weight:400;letter-spacing:.22em;text-transform:uppercase;transition:color .4s}
.nav.h .nav-c,.nav.h .nav-wm{color:rgba(255,255,255,.8)}
.nav.l .nav-c,.nav.l .nav-wm{color:var(--green)}
.nav-burger{display:flex;flex-direction:column;gap:5px;align-items:flex-end;justify-content:center;min-width:44px;min-height:44px;cursor:pointer}
.nav-burger span{display:block;height:1px;transition:background .4s}
.nav.h .nav-burger span{background:rgba(255,255,255,.7)}
.nav.l .nav-burger span{background:var(--green)}
.nav-burger span:first-child{width:22px}
.nav-burger span:last-child{width:13px}

/* HERO — full bleed video/image */
.hero{position:relative;height:100svh;min-height:600px;overflow:hidden;background:#0a0a0a}
.hero-media{position:absolute;inset:0;z-index:1}
.hero-media video,.hero-media img{width:100%;height:100%;object-fit:cover;display:block}
.hero-overlay{position:absolute;inset:0;z-index:2;background:linear-gradient(to top,rgba(0,0,0,.75) 0%,rgba(0,0,0,.15) 50%,rgba(0,0,0,.05) 100%)}
.hero-body{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:0 24px calc(60px + env(safe-area-inset-bottom))}
.hero-eyebrow{font-size:7px;letter-spacing:.6em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:10px}
.hero-title{font-family:var(--fd);font-size:clamp(28px,8vw,44px);font-weight:300;color:rgba(255,255,255,.75);line-height:.95;margin-bottom:6px}
.hero-title em{font-style:italic;color:rgba(184,146,74,.65)}
.hero-sub{font-size:9px;color:rgba(255,255,255,.28);letter-spacing:.06em;line-height:1.8;margin-bottom:24px;max-width:200px}
.hero-cta{display:inline-flex;align-items:center;gap:10px;font-size:7px;letter-spacing:.45em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.hero-cta::after{content:'';width:22px;height:1px;background:rgba(255,255,255,.3);display:block}

/* CATEGORY CARDS — Anglo-Italian style, full bleed, editorial */
.cats{background:#000;display:flex;flex-direction:column}

/* each card is full-width, tall, photo-style */
.cat-card{
  position:relative;
  width:100%;
  height:100svh;
  min-height:580px;
  overflow:hidden;
  display:block;
  text-decoration:none;
  /* white 1px divider via border */
  border-top:1px solid rgba(255,255,255,.12);
}
.cat-card:first-child{border-top:none}

/* dark gradient bg with animated SVG art — no photo */
.cat-card.loafer{background:#0C2118}
.cat-card.oxford{background:#141410}
.cat-card.flex{background:#0A1B12}

/* animated background art — large, centered */
.cat-art{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:1;
  pointer-events:none;
  overflow:hidden;
}
.cat-art svg{
  width:110%;
  max-width:500px;
  opacity:.06;
  transform-origin:center;
  animation:breathe 16s ease-in-out infinite alternate;
}
.cat-card:nth-child(2) .cat-art svg{animation-delay:-5s}
.cat-card:nth-child(3) .cat-art svg{animation-delay:-10s}
@keyframes breathe{
  0%{transform:scale(1) translateY(0)}
  100%{transform:scale(1.08) translateY(-20px)}
}

/* gradient — heavier at bottom like Anglo-Italian */
.cat-grad{
  position:absolute;
  inset:0;
  z-index:2;
  background:linear-gradient(
    to top,
    rgba(0,0,0,.92) 0%,
    rgba(0,0,0,.5) 30%,
    rgba(0,0,0,.15) 60%,
    rgba(0,0,0,0) 100%
  );
}

/* content — bottom left, Anglo-Italian style */
.cat-content{
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  z-index:3;
  padding:0 24px calc(48px + env(safe-area-inset-bottom));
}

/* large ghost number top-right */
.cat-ghost-num{
  position:absolute;
  top:32px;
  right:20px;
  font-family:var(--fd);
  font-size:clamp(80px,25vw,140px);
  font-weight:300;
  color:rgba(255,255,255,.03);
  line-height:1;
  z-index:3;
  user-select:none;
  letter-spacing:-.02em;
}

/* animate in on scroll — starts hidden, slides up */
.cat-tag{
  font-size:7px;
  letter-spacing:.55em;
  text-transform:uppercase;
  color:rgba(184,146,74,.5);
  margin-bottom:14px;
  opacity:0;
  transform:translateY(12px);
  transition:opacity .9s var(--ease),transform .9s var(--ease);
}
.cat-name{
  font-family:var(--fd);
  font-size:clamp(42px,13vw,64px);
  font-weight:300;
  color:#fff;
  line-height:.9;
  margin-bottom:14px;
  letter-spacing:-.01em;
  opacity:0;
  transform:translateY(16px);
  transition:opacity .9s var(--ease) .08s,transform .9s var(--ease) .08s;
}
.cat-desc{
  font-size:10px;
  color:rgba(255,255,255,.35);
  letter-spacing:.04em;
  line-height:1.75;
  margin-bottom:22px;
  max-width:260px;
  opacity:0;
  transform:translateY(12px);
  transition:opacity .9s var(--ease) .16s,transform .9s var(--ease) .16s;
}
.cat-link{
  display:inline-flex;
  align-items:center;
  gap:12px;
  font-size:7px;
  letter-spacing:.48em;
  text-transform:uppercase;
  color:rgba(255,255,255,.5);
  opacity:0;
  transform:translateY(10px);
  transition:opacity .9s var(--ease) .24s,transform .9s var(--ease) .24s;
}
.cat-link::after{
  content:'';
  width:0;
  height:1px;
  background:rgba(255,255,255,.4);
  display:block;
  transition:width .6s var(--ease) .5s;
}

/* when card enters viewport */
.cat-card.visible .cat-tag,
.cat-card.visible .cat-name,
.cat-card.visible .cat-desc,
.cat-card.visible .cat-link{opacity:1;transform:none}
.cat-card.visible .cat-link::after{width:28px}

/* PRODUCTS — light bg */
.col{background:var(--page);padding:60px 0 68px}
.sec-hd{padding:0 24px;margin-bottom:36px}
.sec-ey{display:block;font-size:7px;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.sec-h2{font-family:var(--fd);font-size:clamp(32px,9vw,46px);font-weight:300;color:var(--ink);line-height:1.05}
.sec-h2 em{color:var(--green);font-style:italic}
.bblock{margin-bottom:48px}
.bblock:last-child{margin-bottom:0}
.brow-hd{display:flex;align-items:center;gap:14px;padding:0 24px;margin-bottom:18px}
.brow-name{font-family:var(--fd);font-size:17px;font-weight:300;letter-spacing:.12em;text-transform:uppercase;color:var(--ink);white-space:nowrap}
.brow-rule{flex:1;height:1px;background:rgba(17,17,17,.08)}
.brow-link{font-size:7px;letter-spacing:.32em;text-transform:uppercase;color:var(--green);white-space:nowrap}
.card-row{display:flex;gap:10px;overflow-x:auto;padding:0 24px 2px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.card-row::-webkit-scrollbar{display:none}
.pcard{flex-shrink:0;width:56vw;max-width:190px;scroll-snap-align:start}
.pcard-img{width:100%;aspect-ratio:3/4;position:relative;overflow:hidden;margin-bottom:10px}
.ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center}
.g1{background:var(--green)}.g2{background:#0B2419}.g3{background:#102C20}
.g4{background:#091E15}.g5{background:#0E2820}.g6{background:#0C2218}
.g7{background:#0A1F17}.g8{background:#0D2620}.g9{background:#112B1E}
.ph svg{width:72%;opacity:.15}
.ph-tag{position:absolute;bottom:8px;left:8px;font-size:7px;letter-spacing:.25em;text-transform:uppercase;color:rgba(184,146,74,.6)}
.ph-badge{position:absolute;top:8px;right:8px;background:var(--gold);color:#fff;font-size:6px;letter-spacing:.15em;text-transform:uppercase;padding:3px 6px}
.pcard-brand{font-size:7px;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.pcard-name{font-family:var(--fd);font-size:15px;font-weight:300;color:var(--ink);line-height:1.2;margin-bottom:4px}
.pcard-note{font-size:9px;color:var(--mid);line-height:1.5;margin-bottom:7px}
.pcard-price{font-family:var(--fd);font-size:14px;font-weight:400;color:var(--ink)}

/* OUR FAVOURITE */
.phil{background:var(--green);padding:68px 24px;position:relative;overflow:hidden}
.phil::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 100%,rgba(184,146,74,.06),transparent 70%);pointer-events:none}
.phil .sec-ey{color:rgba(184,146,74,.55)}
.phil .sec-h2{color:#fff}
.phil .sec-h2 em{color:var(--gold2);font-style:italic}
.phil-body{font-family:var(--fd);font-style:italic;font-size:16px;line-height:2;color:rgba(255,255,255,.4);margin:24px 0 44px}
.phil-rows{border-top:1px solid rgba(255,255,255,.08)}
.prow{display:grid;grid-template-columns:36px 1fr;gap:0 16px;padding:22px 0;border-bottom:1px solid rgba(255,255,255,.06);opacity:0;transform:translateX(-10px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.prow.in{opacity:1;transform:none}
.pn{font-family:var(--fd);font-size:26px;font-weight:300;color:rgba(184,146,74,.28);line-height:1;padding-top:4px}
.prow h4{font-size:8px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:6px}
.prow p{font-size:12px;line-height:1.8;color:rgba(255,255,255,.3)}

/* CTA */
.cta{background:var(--page);padding:72px 24px;border-top:1px solid rgba(17,17,17,.06)}
.cta h2{font-family:var(--fd);font-size:clamp(32px,9vw,48px);font-weight:300;color:var(--ink);line-height:1.1}
.cta h2 em{color:var(--green);font-style:italic}
.cta-sub{font-family:var(--fd);font-style:italic;font-size:14px;color:var(--mid);line-height:1.8;margin:14px 0 36px}
.cta-btns{display:flex;flex-direction:column;align-items:flex-start;gap:12px}
.btn-g{display:inline-flex;align-items:center;gap:12px;background:#06C755;color:#fff;font-family:var(--fb);font-size:8px;font-weight:400;letter-spacing:.35em;text-transform:uppercase;padding:16px 32px;min-height:50px}
.btn-p{display:inline-flex;align-items:center;gap:12px;background:var(--green);color:#fff;font-family:var(--fb);font-size:8px;font-weight:400;letter-spacing:.35em;text-transform:uppercase;padding:16px 32px;min-height:50px}
.lico{width:18px;height:18px;flex-shrink:0}

/* FOOTER */
footer{background:var(--green);padding:48px 24px calc(40px + env(safe-area-inset-bottom))}
.ft{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:32px;padding-bottom:28px;border-bottom:1px solid rgba(255,255,255,.08)}
.fc{width:34px;height:34px;border-radius:50%;border:1px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:15px;color:#fff;margin-bottom:7px}
.fw{font-family:var(--fb);font-size:9px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:#fff}
.ftg{font-size:7px;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.22);margin-top:2px}
.fa{text-align:right}
.fa p{font-size:9px;color:rgba(255,255,255,.3);line-height:1.9}
.fa strong{color:rgba(255,255,255,.55);font-weight:400}
.fb2{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:24px}
.fb2 a{font-family:var(--fd);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.26)}
.fn{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:28px}
.fn a{font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.18)}
.fcp{font-size:7px;letter-spacing:.1em;color:rgba(255,255,255,.11)}
.fv{font-size:6px;color:rgba(184,146,74,.14);margin-top:4px}
</style>
</head>
<body>

<nav class="nav h" id="nav">
  <div class="nav-logo"><div class="nav-c">C</div><div class="nav-wm">Curated & Co.</div></div>
  <div class="nav-burger"><span></span><span></span></div>
</nav>

<!-- HERO -->
<div class="hero" id="hero">
  <div class="hero-media">
    {heroVideo && <video autoplay muted loop playsinline src={heroVideo}></video>}
    {!heroVideo && heroImage && <img src={heroImage} alt="Curated & Co."/>}
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-body">
    <div class="hero-eyebrow">Bangkok · Thailand</div>
    <div class="hero-title">Curated<br/><em>&amp; Co.</em></div>
    <div class="hero-sub">A curated edit of Europe's finest shoemaking — for those who know.</div>
    <a href="https://curatedandcobkk.com" class="hero-cta">Discover All</a>
  </div>
</div>

<!-- 3 CATEGORY CARDS — full screen each, Anglo-Italian style -->
<div class="cats">

  <a href="https://curatedandcobkk.com/product-category/berwick-welted-loafers/" class="cat-card loafer" id="cat1">
    <div class="cat-art">
      <svg viewBox="0 0 560 280" fill="none">
        <path d="M48 198C82 138 164 106 254 100C310 96 366 104 412 124C458 144 500 172 514 190C526 204 520 220 500 226C462 237 380 240 272 238C182 236 100 232 68 222C48 216 36 212 48 198Z" fill="#C9A96E"/>
        <rect x="210" y="72" width="140" height="28" rx="14" fill="#C9A96E" opacity="0.6"/>
        <rect x="240" y="52" width="80" height="20" rx="10" fill="#C9A96E" opacity="0.35"/>
      </svg>
    </div>
    <div class="cat-grad"></div>
    <div class="cat-ghost-num">01</div>
    <div class="cat-content">
      <div class="cat-tag">Berwick 1707</div>
      <div class="cat-name">Welted<br/>Loafers</div>
      <div class="cat-desc">Penny, horsebit & tassel — Goodyear welted in Almansa, Spain since 1707</div>
      <div class="cat-link">Shop the Collection</div>
    </div>
  </a>

  <a href="https://curatedandcobkk.com/product-category/oxford-shoes/" class="cat-card oxford" id="cat2">
    <div class="cat-art">
      <svg viewBox="0 0 560 280" fill="none">
        <path d="M52 200C86 140 168 108 258 102C314 98 368 106 414 126C460 146 500 174 514 192C524 206 518 222 498 228C460 239 376 242 268 240C178 238 96 234 64 224C44 218 40 214 52 200Z" fill="#C9A96E"/>
        <path d="M258 102C262 76 266 52 270 38C274 24 282 17 292 21C304 26 306 46 302 68" stroke="#C9A96E" stroke-width="7" stroke-linecap="round" fill="none"/>
        <path d="M215 122C230 118 248 116 265 116" stroke="#C9A96E" stroke-width="3" opacity="0.4" stroke-linecap="round"/>
        <path d="M215 136C230 132 248 130 266 130" stroke="#C9A96E" stroke-width="3" opacity="0.25" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="cat-grad"></div>
    <div class="cat-ghost-num">02</div>
    <div class="cat-content">
      <div class="cat-tag">Berwick 1707</div>
      <div class="cat-name">Oxford<br/>Shoes</div>
      <div class="cat-desc">Shell cordovan & box calf — the pinnacle of formal dress, built to last decades</div>
      <div class="cat-link">Shop the Collection</div>
    </div>
  </a>

  <a href="https://curatedandcobkk.com/product-category/berwick-flex-walks/" class="cat-card flex" id="cat3">
    <div class="cat-art">
      <svg viewBox="0 0 560 280" fill="none">
        <path d="M40 195C70 130 158 100 250 97C306 95 360 105 406 128C452 151 496 178 510 195C522 208 516 224 494 230C454 240 368 244 260 242C168 240 88 236 58 226C36 219 28 210 40 195Z" fill="#C9A96E"/>
        <path d="M250 97C253 74 256 56 260 44C264 32 272 26 280 29" stroke="#C9A96E" stroke-width="8" stroke-linecap="round" fill="none"/>
        <circle cx="192" cy="178" r="12" fill="#C9A96E" opacity="0.2"/>
        <circle cx="328" cy="178" r="12" fill="#C9A96E" opacity="0.2"/>
      </svg>
    </div>
    <div class="cat-grad"></div>
    <div class="cat-ghost-num">03</div>
    <div class="cat-content">
      <div class="cat-tag">Berwick 1707</div>
      <div class="cat-name">Flex<br/>Walks</div>
      <div class="cat-desc">Blake-stitched comfort for the Bangkok lifestyle — lighter, more flexible, just as refined</div>
      <div class="cat-link">Shop the Collection</div>
    </div>
  </a>

</div>

<!-- PRODUCTS -->
<section class="col">
  <div class="sec-hd"><span class="sec-ey rv">The Edit</span><h2 class="sec-h2 rv d1">Selected<br/><em>for Bangkok</em></h2></div>
  <div class="bblock rv d1">
    <div class="brow-hd"><div class="brow-name">Berwick 1707</div><div class="brow-rule"></div><a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="brow-link">View All</a></div>
    <div class="card-row">
      <a href="https://curatedandcobkk.com/product-category/berwick-welted-loafers/" class="pcard"><div class="pcard-img"><div class="ph g1"><svg viewBox="0 0 300 200" fill="none"><path d="M28 138C50 94 110 72 166 68C200 66 234 72 262 86C290 100 308 118 314 130C320 140 316 150 302 155C276 162 224 165 164 163C114 161 64 158 44 152C30 147 22 145 28 138Z" fill="#C9A96E"/><rect x="138" y="52" width="70" height="18" rx="4" fill="#C9A96E" opacity="0.5"/></svg><div class="ph-tag">Penny Loafer</div><div class="ph-badge">New</div></div></div><div class="pcard-brand">Berwick 1707</div><div class="pcard-name">9628 Box Calf</div><div class="pcard-note">Goodyear welted · Last 8</div><div class="pcard-price">฿8,800</div></a>
      <a href="https://curatedandcobkk.com/product-category/berwick-welted-loafers/" class="pcard"><div class="pcard-img"><div class="ph g2"><svg viewBox="0 0 300 200" fill="none"><path d="M28 138C50 94 110 72 166 68C200 66 234 72 262 86C290 100 308 118 314 130C320 140 316 150 302 155C276 162 224 165 164 163C114 161 64 158 44 152C30 147 22 145 28 138Z" fill="#C9A96E"/><rect x="142" y="46" width="62" height="10" rx="3" fill="#C9A96E" opacity="0.65"/></svg><div class="ph-tag">Horsebit</div></div></div><div class="pcard-brand">Berwick 1707</div><div class="pcard-name">Horsebit Suede</div><div class="pcard-note">Unlined · Blake stitch</div><div class="pcard-price">฿7,500</div></a>
