---
const heroImage = "https://res.cloudinary.com/dynjnftnu/image/upload/v1777049840/Oxfords_hkfvai.jpg";
const heroVideo = "https://res.cloudinary.com/dynjnftnu/video/upload/v1777050102/Landing_-_V_kll7wf.mp4";
const brandStory = "Berwick 1707 represents the pinnacle of Spanish shoemaking tradition. Every pair is crafted by hand at the Berwick artisan floor in Almansa, using the finest leathers and time-honoured Goodyear welt construction.";
const ctaText = "Shop the Collection";
const ctaUrl = "https://curatedandcobkk.com/product-category/brands/berwick/";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content="Berwick 1707 — Handcrafted Spanish shoes, exclusively curated for Bangkok by Curated & Co." />
  <title>Berwick 1707 — Curated & Co. Bangkok</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Tenor+Sans&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #F5F0E8;
      --parchment: #EDE5D4;
      --tan: #C9A96E;
      --tan-dark: #A07C3E;
      --brown: #3D2B1F;
      --brown-mid: #6B4226;
      --brown-light: #8B5E3C;
      --charcoal: #1A1208;
      --white: #FDFAF5;
      --gold: #C9A96E;
      --font-display: 'Cormorant Garamond', Georgia, serif;
      --font-body: 'Tenor Sans', sans-serif;
      --font-italic: 'EB Garamond', Georgia, serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--charcoal);
      color: var(--cream);
      font-family: var(--font-body);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAVBAR ── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 24px;
      padding-top: calc(20px + env(safe-area-inset-top));
      background: linear-gradient(to bottom, rgba(26,18,8,0.9) 0%, transparent 100%);
      transition: background 0.4s ease;
    }
    .nav.scrolled {
      background: rgba(26,18,8,0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 300;
      letter-spacing: 0.25em;
      color: var(--cream);
      text-decoration: none;
      text-transform: uppercase;
    }
    .nav-logo span {
      color: var(--gold);
    }
    .nav-line {
      width: 28px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      min-height: 48px;
      min-width: 48px;
      align-items: flex-end;
      justify-content: center;
    }
    .nav-line span {
      display: block;
      height: 1px;
      background: var(--cream);
      transition: all 0.3s;
    }
    .nav-line span:first-child { width: 28px; }
    .nav-line span:last-child { width: 18px; }

    /* ── HERO ── */
    .hero {
      position: relative;
      height: 100svh;
      min-height: 600px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      overflow: hidden;
      padding-bottom: 72px;
    }

    .hero-media {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transform-origin: center;
      animation: slowZoom 20s ease-in-out infinite alternate;
    }
    @keyframes slowZoom {
      from { transform: scale(1); }
      to   { transform: scale(1.08); }
    }

    .hero-video {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      animation: slowZoom 20s ease-in-out infinite alternate;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(26,18,8,0.15) 0%,
        rgba(26,18,8,0.1) 30%,
        rgba(26,18,8,0.55) 65%,
        rgba(26,18,8,0.92) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 0 32px;
      opacity: 0;
      transform: translateY(24px);
      animation: fadeUp 1.2s ease 0.4s forwards;
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 0.4em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 16px;
      opacity: 0;
      animation: fadeUp 1s ease 0.7s forwards;
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(52px, 14vw, 80px);
      font-weight: 300;
      line-height: 1;
      color: var(--white);
      letter-spacing: 0.02em;
      margin-bottom: 12px;
      opacity: 0;
      animation: fadeUp 1s ease 0.9s forwards;
    }

    .hero-sub {
      font-family: var(--font-italic);
      font-style: italic;
      font-size: clamp(14px, 3.5vw, 18px);
      color: var(--parchment);
      letter-spacing: 0.05em;
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeUp 1s ease 1.1s forwards;
    }

    .hero-cta {
      display: inline-block;
      padding: 16px 40px;
      border: 1px solid var(--gold);
      color: var(--gold);
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s ease;
      min-height: 52px;
      display: inline-flex;
      align-items: center;
      opacity: 0;
      animation: fadeUp 1s ease 1.3s forwards;
    }
    @media (hover: hover) {
      .hero-cta:hover {
        background: var(--gold);
        color: var(--charcoal);
      }
    }

    .hero-scroll {
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0;
      animation: fadeUp 1s ease 1.8s forwards;
    }
    .hero-scroll span {
      font-size: 9px;
      letter-spacing: 0.3em;
      color: var(--tan);
      text-transform: uppercase;
    }
    .scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--tan), transparent);
      animation: scrollPulse 2s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.1); }
    }

    /* ── MARQUEE ── */
    .marquee-wrap {
      background: var(--tan);
      padding: 14px 0;
      overflow: hidden;
    }
    .marquee-track {
      display: flex;
      gap: 0;
      animation: marquee 25s linear infinite;
      width: max-content;
    }
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .marquee-item {
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--charcoal);
      padding: 0 28px;
      white-space: nowrap;
    }
    .marquee-dot {
      color: var(--brown);
      padding: 0 4px;
    }

    /* ── SECTION BASE ── */
    section {
      padding: 80px 24px;
    }
    .section-eyebrow {
      font-size: 9px;
      letter-spacing: 0.45em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 20px;
      display: block;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(36px, 9vw, 52px);
      font-weight: 300;
      line-height: 1.1;
      color: var(--white);
      margin-bottom: 20px;
    }
    .section-title em {
      font-style: italic;
      color: var(--tan);
    }
    .divider {
      width: 40px;
      height: 1px;
      background: var(--tan);
      margin: 24px 0;
    }

    /* ── COLLECTION ── */
    .collection {
      background: var(--charcoal);
      padding-top: 64px;
    }
    .collection-header {
      text-align: center;
      margin-bottom: 48px;
    }
    .collection-grid {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .collection-card {
      position: relative;
      height: 56vw;
      max-height: 320px;
      overflow: hidden;
      cursor: pointer;
      text-decoration: none;
    }
    .collection-card img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.8s ease;
      filter: brightness(0.75) saturate(0.9);
    }
    @media (hover: hover) {
      .collection-card:hover img { transform: scale(1.05); }
    }
    .collection-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,18,8,0.85) 0%, transparent 55%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 24px 20px;
    }
    .collection-card-label {
      font-size: 9px;
      letter-spacing: 0.35em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .collection-card-name {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 300;
      color: var(--white);
      line-height: 1;
    }
    .collection-card-arrow {
      margin-top: 12px;
      width: 32px;
      height: 1px;
      background: var(--gold);
      position: relative;
    }
    .collection-card-arrow::after {
      content: '';
      position: absolute;
      right: 0; top: -3px;
      width: 7px; height: 7px;
      border-top: 1px solid var(--gold);
      border-right: 1px solid var(--gold);
      transform: rotate(45deg);
    }

    /* ── CRAFTSMANSHIP ── */
    .craft {
      background: var(--brown);
      position: relative;
      overflow: hidden;
    }
    .craft::before {
      content: '1707';
      position: absolute;
      right: -20px; top: 40px;
      font-family: var(--font-display);
      font-size: 120px;
      font-weight: 300;
      color: rgba(201,169,110,0.08);
      line-height: 1;
      pointer-events: none;
    }
    .craft-body {
      font-family: var(--font-italic);
      font-size: 17px;
      font-style: italic;
      line-height: 1.9;
      color: var(--parchment);
      margin-bottom: 40px;
    }
    .craft-pillars {
      display: flex;
      flex-direction: column;
      gap: 28px;
      margin-top: 40px;
    }
    .craft-pillar {
      display: flex;
      gap: 20px;
      align-items: flex-start;
      opacity: 0;
      transform: translateX(-20px);
      transition: all 0.6s ease;
    }
    .craft-pillar.visible {
      opacity: 1;
      transform: translateX(0);
    }
    .craft-pillar-num {
      font-family: var(--font-display);
      font-size: 36px;
      font-weight: 300;
      color: var(--tan);
      line-height: 1;
      flex-shrink: 0;
      width: 40px;
    }
    .craft-pillar-text h4 {
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 6px;
    }
    .craft-pillar-text p {
      font-size: 13px;
      line-height: 1.7;
      color: rgba(237,229,212,0.7);
    }

    /* ── LOOKS / INSTAGRAM ── */
    .looks {
      background: var(--cream);
      color: var(--charcoal);
      padding: 64px 0;
    }
    .looks-header {
      padding: 0 24px;
      margin-bottom: 32px;
    }
    .looks .section-title { color: var(--charcoal); }
    .looks .section-eyebrow { color: var(--brown-mid); }
    .looks-scroll {
      display: flex;
      gap: 2px;
      overflow-x: auto;
      padding: 0 24px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .looks-scroll::-webkit-scrollbar { display: none; }
    .looks-item {
      flex-shrink: 0;
      width: 72vw;
      max-width: 280px;
      aspect-ratio: 3/4;
      scroll-snap-align: start;
      overflow: hidden;
      position: relative;
      background: var(--parchment);
    }
    .looks-item img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .looks-item-placeholder {
      width: 100%; height: 100%;
      background: linear-gradient(135deg, var(--parchment) 0%, var(--tan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .looks-item-placeholder span {
      font-family: var(--font-display);
      font-size: 11px;
      letter-spacing: 0.3em;
      color: var(--brown);
      text-transform: uppercase;
    }
    .looks-insta-cta {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 32px 24px 0;
      text-decoration: none;
      color: var(--brown);
    }
    .looks-insta-cta span {
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }
    .looks-insta-cta .arrow-line {
      flex: 1;
      height: 1px;
      background: var(--tan);
      position: relative;
      max-width: 60px;
    }
    .looks-insta-cta .arrow-line::after {
      content: '';
      position: absolute;
      right: 0; top: -3px;
      width: 6px; height: 6px;
      border-top: 1px solid var(--brown-mid);
      border-right: 1px solid var(--brown-mid);
      transform: rotate(45deg);
    }

    /* ── LINE CTA ── */
    .line-cta {
      background: var(--charcoal);
      padding: 80px 24px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .line-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(201,169,110,0.08) 0%, transparent 70%);
    }
    .line-cta-inner { position: relative; z-index: 1; }
    .line-cta .section-title { margin-bottom: 12px; }
    .line-cta-sub {
      font-family: var(--font-italic);
      font-style: italic;
      font-size: 15px;
      color: rgba(237,229,212,0.6);
      margin-bottom: 40px;
      line-height: 1.7;
    }
    .line-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #06C755;
      color: #fff;
      padding: 18px 36px;
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      text-decoration: none;
      min-height: 56px;
      transition: opacity 0.2s;
    }
    @media (hover: hover) { .line-btn:hover { opacity: 0.85; } }
    .line-icon { width: 22px; height: 22px; }

    .shop-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      border: 1px solid var(--gold);
      color: var(--gold);
      padding: 18px 36px;
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      text-decoration: none;
      min-height: 56px;
      margin-top: 16px;
      transition: all 0.3s;
    }
    @media (hover: hover) {
      .shop-btn:hover { background: var(--gold); color: var(--charcoal); }
    }
    .cta-btns {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--brown);
      padding: 48px 24px;
      padding-bottom: calc(48px + env(safe-area-inset-bottom));
      text-align: center;
    }
    .footer-logo {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 300;
      letter-spacing: 0.2em;
      color: var(--cream);
      margin-bottom: 8px;
    }
    .footer-sub {
      font-size: 10px;
      letter-spacing: 0.3em;
      color: var(--tan);
      text-transform: uppercase;
      margin-bottom: 32px;
    }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }
    .footer-links a {
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(237,229,212,0.5);
      text-decoration: none;
    }
    .footer-copy {
      font-size: 10px;
      color: rgba(237,229,212,0.3);
      letter-spacing: 0.1em;
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">Curated <span>&</span> Co.</a>
    <a href="https://curatedandcobkk.com" class="nav-logo" style="font-size:9px;letter-spacing:0.3em;color:var(--tan)">BERWICK 1707</a>
    <div class="nav-line" aria-label="Menu">
      <span></span>
      <span></span>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    {heroVideo ? (
      <video class="hero-video" autoplay muted loop playsinline poster={heroImage || ''}>
        <source src={heroVideo} type="video/mp4" />
      </video>
    ) : heroImage ? (
      <img class="hero-media" src={heroImage} alt="Berwick 1707" />
    ) : (
      <!-- Fallback gradient when no media uploaded yet -->
      <div style="position:absolute;inset:0;background:linear-gradient(160deg,#3D2B1F 0%,#1A1208 40%,#6B4226 100%);"></div>
    )}
    <div class="hero-overlay"></div>

    <div class="hero-content">
      <p class="hero-eyebrow">Curated & Co. Bangkok — Official Berwick Retailer</p>
      <h1 class="hero-title">Berwick<br/>1707</h1>
      <p class="hero-sub">Handcrafted in Almansa, Spain since 1707</p>
      <a href={ctaUrl} class="hero-cta">{ctaText}</a>
    </div>

    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      {[...Array(2)].map(() => (
        <>
          <span class="marquee-item">Goodyear Welted</span>
          <span class="marquee-item marquee-dot">·</span>
          <span class="marquee-item">Almansa, Spain</span>
          <span class="marquee-item marquee-dot">·</span>
          <span class="marquee-item">Since 1707</span>
          <span class="marquee-item marquee-dot">·</span>
          <span class="marquee-item">Shell Cordovan</span>
          <span class="marquee-item marquee-dot">·</span>
          <span class="marquee-item">Box Calf</span>
          <span class="marquee-item marquee-dot">·</span>
          <span class="marquee-item">Handcrafted</span>
          <span class="marquee-item marquee-dot">·</span>
          <span class="marquee-item">Bangkok Exclusive</span>
          <span class="marquee-item marquee-dot">·</span>
        </>
      ))}
    </div>
  </div>

  <!-- COLLECTION -->
  <section class="collection">
    <div class="collection-header reveal">
      <span class="section-eyebrow">The Collection</span>
      <h2 class="section-title">Berwick <em>for</em><br/>Bangkok</h2>
    </div>

    <div class="collection-grid">
      <a href="https://curatedandcobkk.com/product-category/shoes/penny-loafer/" class="collection-card reveal reveal-delay-1">
        <img src="https://via.placeholder.com/800x450/3D2B1F/C9A96E?text=Penny+Loafer" alt="Penny Loafer" loading="lazy" />
        <div class="collection-card-overlay">
          <span class="collection-card-label">Berwick 1707</span>
          <div class="collection-card-name">Penny<br/>Loafer</div>
          <div class="collection-card-arrow"></div>
        </div>
      </a>

      <a href="https://curatedandcobkk.com/product-category/shoes/horsebit-loafer/" class="collection-card reveal reveal-delay-2">
        <img src="https://via.placeholder.com/800x450/6B4226/C9A96E?text=Horsebit+Loafer" alt="Horsebit Loafer" loading="lazy" />
        <div class="collection-card-overlay">
          <span class="collection-card-label">Berwick 1707</span>
          <div class="collection-card-name">Horsebit<br/>Loafer</div>
          <div class="collection-card-arrow"></div>
        </div>
      </a>

      <a href="https://curatedandcobkk.com/product-category/shoes/oxford/" class="collection-card reveal reveal-delay-3">
        <img src="https://via.placeholder.com/800x450/1A1208/C9A96E?text=Oxford" alt="Oxford" loading="lazy" />
        <div class="collection-card-overlay">
          <span class="collection-card-label">Berwick 1707</span>
          <div class="collection-card-name">Oxford</div>
          <div class="collection-card-arrow"></div>
        </div>
      </a>
    </div>
  </section>

  <!-- CRAFTSMANSHIP -->
  <section class="craft">
    <span class="section-eyebrow reveal">The Craft</span>
    <h2 class="section-title reveal">An Art<br/><em>Three Centuries</em><br/>in the Making</h2>
    <div class="divider reveal"></div>
    <p class="craft-body reveal">{brandStory}</p>

    <div class="craft-pillars">
      <div class="craft-pillar">
        <div class="craft-pillar-num">01</div>
        <div class="craft-pillar-text">
          <h4>Goodyear Welt</h4>
