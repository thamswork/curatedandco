      <div class="cat-name-wrap"><span class="cat-name">{cat3.name1}<br/>{cat3.name2}</span></div>
      <div class="cat-desc">{cat3.desc}</div>
      <div class="cat-link">Shop the Collection<span class="cat-link-line"></span></div>
    </div>
  </a>
</div>

<!-- OUR FAVORITES — 2 col grid -->
<section class="prods">
  <div class="sec-hd">
    <span class="sec-ey rv">The Edit</span>
    <h2 class="sec-h2 rv d1">Our<br/><em>Favorites</em></h2>
