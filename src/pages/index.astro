</nav>

<!-- MOBILE DRAWER -->
<div class="nav-drawer" id="drawer">
  <div class="nav-drawer-bg" id="drawerBg"></div>
  <div class="nav-drawer-panel">
    <a href="https://curatedandcobkk.com/product-category/brands/" class="drawer-link">Brands</a>
    <a href="https://curatedandcobkk.com/shop/" class="drawer-link">Shop</a>
    <a href="https://curatedandcobkk.com/product-category/accessories/" class="drawer-link">Accessories</a>
    <a href="https://curatedandcobkk.com/blog/" class="drawer-link">Journal</a>
    <a href="https://curatedandcobkk.com/#looks" class="drawer-link">Looks</a>
    <a href="https://curatedandcobkk.com/#store" class="drawer-link">Store</a>
    <div class="drawer-icons">
      <a href="https://curatedandcobkk.com/?s=" aria-label="Search">
        <svg viewBox="0 0 24 24" stroke-width="1.5" stroke="#0D2B1F" fill="none"><circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L21 21" stroke-linecap="round"/></svg>
      </a>
      <a href="https://curatedandcobkk.com/cart/" aria-label="Cart">
        <svg viewBox="0 0 24 24" stroke-width="1.5" stroke="#0D2B1F" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </a>
      <a href="https://www.instagram.com/curatedandcobkk/" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" stroke-width="1.5" stroke="#0D2B1F" fill="none"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="#0D2B1F"/></svg>
