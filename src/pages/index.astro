---
import homeData from '../../public/home.json';
const { heroImage = '', heroVideo = '', brandStory = '', ctaText = 'Discover All', ctaUrl = '' } = homeData;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<title>Curated & Co. Bangkok</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
a{color:inherit;text-decoration:none}
:root{
--green:#0D2B1F;--gold:#B8924A;--gold2:#CFA55A;
--cream:#F7F4EF;--page:#FAFAF8;--ink:#111;--mid:#5A5A58;
--ease:cubic-bezier(0.16,1,0.3,1);
--fd:'Cormorant Garamond',Georgia,serif;
--fb:'Jost',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--page);color:var(--ink);font-family:var(--fb);font-weight:300;overflow-x:hidden;-webkit-font-smoothing:antialiased}
.rv{opacity:0;transform:translateY(20px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.rv.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}
.nav{position:fixed;inset:0 0 auto 0;z-index:300;height:calc(60px + env(safe-area-inset-top));padding:env(safe-area-inset-top) 20px 0;display:flex;align-items:center;justify-content:space-between;transition:all .5s var(--ease)}
.nav.h{background:linear-gradient(to bottom,rgba(13,43,31,.85),transparent)}
.nav.l{background:var(--page);border-bottom:1px solid rgba(17,17,17,.07)}
.nav-logo{display:flex;align-items:center;gap:10px}
.nav-c{width:32px;height:32px;border-radius:50%;border:1.5px solid currentColor;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:14px;font-weight:300;transition:color .4s}
.nav-wm{font-family:var(--fb);font-size:11px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;transition:color .4s}
.nav.h .nav-c,.nav.h .nav-wm{color:#fff}
.nav.l .nav-c,.nav.l .nav-wm{color:var(--green)}
.nav-burger{display:flex;flex-direction:column;gap:5px;align-items:flex-end;justify-content:center;min-width:48px;min-height:48px;padding-left:12px;cursor:pointer}
.nav-burger span{display:block;height:1px;transition:background .4s}
.nav.h .nav-burger span{background:#fff}
.nav.l .nav-burger span{background:var(--green)}
.nav-burger span:first-child{width:24px}
.nav-burger span:last-child{width:14px}
.hero{position:relative;height:100svh;min-height:600px;overflow:hidden;background:var(--green)}
.slides{display:flex;height:100%;transition:transform .9s var(--ease);will-change:transform}
.slide{flex-shrink:0;width:100%;height:100%;position:relative;display:flex;flex-direction:column;justify-content:flex-end;padding:0 28px 72px}
.s0{background:linear-gradient(160deg,#0A2219,#0D2B1F 60%,#112E22)}
.s1{background:linear-gradient(155deg,#091E15,#0B2519 60%,#0E2B1E)}
.s2{background:linear-gradient(165deg,#0B2018,#0D271C 60%,#102A20)}
.s3{background:linear-gradient(150deg,#0A1F17,#0C2419 60%,#0F291D)}
.sacc{position:absolute;top:0;left:28px;right:28px;height:1px;background:linear-gradient(to right,transparent,rgba(184,146,74,.4),transparent);z-index:2}
.sart{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;z-index:1}
.sart svg{width:78%;max-width:340px;opacity:.08;animation:af 18s ease-in-out infinite alternate}
@keyframes af{from{transform:scale(1)}to{transform:scale(1.05) translateY(-14px)}}
.sbody{position:relative;z-index:3}
.sorg{font-size:9px;letter-spacing:.5em;text-transform:uppercase;color:rgba(184,146,74,.7);margin-bottom:18px}
.sbrand{font-family:var(--fd);font-size:clamp(54px,16vw,88px);font-weight:300;color:#fff;line-height:.9;margin-bottom:6px}
.ssub{font-family:var(--fd);font-size:clamp(16px,4.5vw,22px);font-weight:300;font-style:italic;color:rgba(184,146,74,.85);letter-spacing:.15em;margin-bottom:20px}
.sdesc{font-size:12px;color:rgba(255,255,255,.42);letter-spacing:.05em;line-height:1.7;margin-bottom:36px;max-width:280px}
.sbtn{display:inline-flex;align-items:center;gap:12px;border:1px solid rgba(184,146,74,.5);color:rgba(184,146,74,.9);font-family:var(--fb);font-size:9px;font-weight:400;letter-spacing:.38em;text-transform:uppercase;padding:14px 30px;min-height:48px;transition:background .3s,color .3s}
@media(hover:hover){.sbtn:hover{background:var(--gold);color:#fff}}
.slide.on .sorg,.slide.on .sbrand,.slide.on .ssub,.slide.on .sdesc,.slide.on .sbtn{animation:su .7s var(--ease) both}
.slide.on .sbrand{animation-delay:.1s}.slide.on .ssub{animation-delay:.22s}.slide.on .sdesc{animation-delay:.32s}.slide.on .sbtn{animation-delay:.42s}
@keyframes su{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
.hero-dots{position:absolute;bottom:28px;right:24px;display:flex;flex-direction:column;gap:8px;z-index:10}
.dot{width:1px;height:20px;background:rgba(255,255,255,.22);border:none;cursor:pointer;padding:0;transition:background .3s,height .3s}
.dot.on{background:var(--gold);height:32px}
.bstrip{background:var(--green);padding:18px 24px;display:flex;align-items:center;justify-content:space-between}
.bstrip-lbl{font-size:8px;letter-spacing:.45em;text-transform:uppercase;color:rgba(255,255,255,.3)}
.bstrip-list{display:flex;gap:18px;align-items:center}
.bstrip-list a{font-family:var(--fd);font-size:13px;font-weight:300;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5);transition:color .2s}
.bstrip-list a.on{color:var(--gold)}
.bstrip-sep{color:rgba(255,255,255,.12);font-size:10px}
.col{background:var(--page);padding:64px 0 72px}
.sec-hd{padding:0 24px;margin-bottom:40px}
.sec-ey{display:block;font-size:8px;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:12px}
.sec-h2{font-family:var(--fd);font-size:clamp(34px,9vw,48px);font-weight:300;color:var(--ink);line-height:1.05}
.sec-h2 em{color:var(--green);font-style:italic}
.bblock{margin-bottom:52px}
.bblock:last-child{margin-bottom:0}
.brow-hd{display:flex;align-items:center;gap:14px;padding:0 24px;margin-bottom:20px}
.brow-name{font-family:var(--fd);font-size:18px;font-weight:300;letter-spacing:.14em;text-transform:uppercase;color:var(--ink);white-space:nowrap}
.brow-rule{flex:1;height:1px;background:rgba(17,17,17,.08)}
.brow-link{font-size:8px;letter-spacing:.32em;text-transform:uppercase;color:var(--green);white-space:nowrap;display:flex;align-items:center;gap:6px}
.brow-link::after{content:'';width:18px;height:1px;background:var(--green);display:block;transition:width .3s}
.card-row{display:flex;gap:10px;overflow-x:auto;padding:0 24px 2px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.card-row::-webkit-scrollbar{display:none}
.pcard{flex-shrink:0;width:58vw;max-width:200px;scroll-snap-align:start}
.pcard-img{width:100%;aspect-ratio:3/4;position:relative;overflow:hidden;margin-bottom:12px}
.ph{width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center}
.g1{background:var(--green)}.g2{background:#0B2419}.g3{background:#102C20}
.g4{background:#091E15}.g5{background:#0E2820}.g6{background:#0C2218}
.g7{background:#0A1F17}.g8{background:#0D2620}.g9{background:#112B1E}
.ph svg{width:72%;opacity:.18;position:relative;z-index:1}
.ph-tag{position:absolute;bottom:10px;left:10px;font-size:7px;letter-spacing:.28em;text-transform:uppercase;color:rgba(184,146,74,.6);z-index:2}
.ph-badge{position:absolute;top:8px;right:8px;background:var(--gold);color:#fff;font-size:7px;letter-spacing:.18em;text-transform:uppercase;padding:3px 7px;z-index:3}
.pcard-brand{font-size:7px;letter-spacing:.38em;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
.pcard-name{font-family:var(--fd);font-size:16px;font-weight:300;color:var(--ink);line-height:1.2;margin-bottom:5px}
.pcard-note{font-size:10px;color:var(--mid);line-height:1.5;margin-bottom:8px}
.pcard-price{font-family:var(--fd);font-size:15px;font-weight:400;color:var(--ink)}
.phil{background:var(--green);padding:72px 24px;position:relative;overflow:hidden}
.phil::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 100%,rgba(184,146,74,.07),transparent 70%);pointer-events:none}
.phil .sec-ey{color:rgba(184,146,74,.6)}
.phil .sec-h2{color:#fff}
.phil .sec-h2 em{color:var(--gold2);font-style:italic}
.phil-body{font-family:var(--fd);font-style:italic;font-size:17px;line-height:2;color:rgba(255,255,255,.48);margin:28px 0 48px}
.phil-rows{border-top:1px solid rgba(255,255,255,.08)}
.prow{display:grid;grid-template-columns:36px 1fr;gap:0 16px;padding:24px 0;border-bottom:1px solid rgba(255,255,255,.06);opacity:0;transform:translateX(-10px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.prow.in{opacity:1;transform:none}
.pn{font-family:var(--fd);font-size:28px;font-weight:300;color:rgba(184,146,74,.35);line-height:1;padding-top:4px}
.prow h4{font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.75);margin-bottom:7px}
.prow p{font-size:13px;line-height:1.8;color:rgba(255,255,255,.35)}
.looks{background:var(--cream);padding:64px 0}
.looks .sec-h2 em{color:var(--green)}
.looks .sec-ey{color:var(--green)}
.looks-reel{display:flex;gap:2px;overflow-x:auto;padding:0 24px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.looks-reel::-webkit-scrollbar{display:none}
.lcard{flex-shrink:0;width:66vw;max-width:240px;aspect-ratio:3/4;scroll-snap-align:start;overflow:hidden;position:relative}
.lph{width:100%;height:100%;display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-end;padding:18px;position:relative}
.lph::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(13,43,31,.92) 0%,rgba(13,43,31,.2) 55%,transparent 100%);z-index:1}
.lp1{background:#0D2B1F}.lp2{background:#0B2419}.lp3{background:#102C20}.lp4{background:#0A2018}
.lph svg{position:absolute;top:50%;left:50%;transform:translate(-50%,-55%);width:74%;opacity:.14}
.llbl{position:relative;z-index:2}
.llbl span{display:block;font-size:7px;letter-spacing:.4em;text-transform:uppercase;color:rgba(184,146,74,.7)}
.llbl strong{display:block;font-family:var(--fd);font-size:20px;font-weight:300;color:#fff;margin-top:3px}
.looks-ig{display:flex;align-items:center;gap:12px;padding:26px 24px 0}
.looks-ig span{font-size:8px;letter-spacing:.4em;text-transform:uppercase;color:var(--green)}
.ig-dash{width:40px;height:1px;background:var(--green);flex-shrink:0}
.cta{background:var(--page);padding:80px 24px;border-top:1px solid rgba(17,17,17,.06)}
.cta h2{font-family:var(--fd);font-size:clamp(36px,10vw,52px);font-weight:300;color:var(--ink);line-height:1.1}
.cta h2 em{color:var(--green);font-style:italic}
.cta-sub{font-family:var(--fd);font-style:italic;font-size:15px;color:var(--mid);line-height:1.8;margin:16px 0 40px}
.cta-btns{display:flex;flex-direction:column;align-items:flex-start;gap:12px}
.btn-g{display:inline-flex;align-items:center;gap:12px;background:#06C755;color:#fff;font-family:var(--fb);font-size:9px;font-weight:400;letter-spacing:.35em;text-transform:uppercase;padding:17px 36px;min-height:52px;transition:opacity .25s}
.btn-p{display:inline-flex;align-items:center;gap:12px;background:var(--green);color:#fff;font-family:var(--fb);font-size:9px;font-weight:400;letter-spacing:.35em;text-transform:uppercase;padding:17px 36px;min-height:52px;transition:opacity .25s}
@media(hover:hover){.btn-g:hover,.btn-p:hover{opacity:.85}}
.lico{width:18px;height:18px;flex-shrink:0}
footer{background:var(--green);padding:52px 24px calc(44px + env(safe-area-inset-bottom))}
.ft{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:36px;padding-bottom:32px;border-bottom:1px solid rgba(255,255,255,.08)}
.fc{width:36px;height:36px;border-radius:50%;border:1.5px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:16px;font-weight:300;color:#fff;margin-bottom:8px}
.fw{font-family:var(--fb);font-size:10px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:#fff}
.ftg{font-size:8px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-top:2px}
.fa{text-align:right}
.fa p{font-size:10px;color:rgba(255,255,255,.35);line-height:1.9}
.fa strong{color:rgba(255,255,255,.65);font-weight:400}
.fb2{display:flex;gap:18px;flex-wrap:wrap;margin-bottom:28px}
.fb2 a{font-family:var(--fd);font-size:12px;font-weight:300;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.32);transition:color .2s}
.fn{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:32px}
.fn a{font-size:8px;letter-spacing:.32em;text-transform:uppercase;color:rgba(255,255,255,.22);transition:color .2s}
.fcp{font-size:8px;letter-spacing:.1em;color:rgba(255,255,255,.14)}
.fv{font-size:7px;color:rgba(184,146,74,.18);margin-top:5px}
</style>
</head>
<body>
<nav class="nav h" id="nav">
  <div class="nav-logo"><div class="nav-c">C</div><div class="nav-wm">Curated & Co.</div></div>
  <div class="nav-burger"><span></span><span></span></div>
</nav>
<div class="hero" id="hero">
  <div class="slides" id="slides">
    <div class="slide s0 on">
      <div class="sacc"></div>
      {heroVideo && <video style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0" autoplay muted loop playsinline src={heroVideo}></video>}
      {!heroVideo && heroImage && <img style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0" src={heroImage} alt="Hero"/>}
      <div class="sart" aria-hidden="true"><svg viewBox="0 0 400 400" fill="none"><circle cx="200" cy="200" r="140" stroke="#C9A96E" stroke-width="1" opacity="0.6"/><circle cx="200" cy="200" r="100" stroke="#C9A96E" stroke-width="0.5" opacity="0.3"/><path d="M200 60 A140 140 0 0 0 60 200" stroke="#C9A96E" stroke-width="2" opacity="0.4"/></svg></div>
      <div class="sbody">
        <div class="sorg">Bangkok · Thailand</div>
        <div class="sbrand">Curated<br/><em style="font-style:italic;color:rgba(184,146,74,.85)">&amp; Co.</em></div>
        <div class="sdesc">A curated edit of Europe's finest shoemaking — for those who know.</div>
        <a href="https://curatedandcobkk.com" class="sbtn">Discover All</a>
      </div>
    </div>
    <div class="slide s1">
      <div class="sacc"></div>
      <div class="sart" aria-hidden="true"><svg viewBox="0 0 560 280" fill="none"><path d="M48 198C82 138 164 106 254 100C310 96 366 104 412 124C458 144 500 172 514 190C526 204 520 220 500 226C462 237 380 240 272 238C182 236 100 232 68 222C48 216 36 212 48 198Z" fill="#C9A96E"/><rect x="224" y="80" width="112" height="24" rx="6" fill="#C9A96E" opacity="0.55"/></svg></div>
      <div class="sbody">
        <div class="sorg">Almansa · Spain</div>
        <div class="sbrand">Berwick</div>
        <div class="ssub">1707</div>
        <div class="sdesc">Goodyear welted. Shell cordovan. Box calf. Handcrafted since 1707.</div>
        <a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="sbtn">Shop Berwick</a>
      </div>
    </div>
    <div class="slide s2">
      <div class="sacc"></div>
      <div class="sart" aria-hidden="true"><svg viewBox="0 0 560 280" fill="none"><path d="M52 200C86 140 168 108 258 102C314 98 368 106 414 126C460 146 500 174 514 192C524 206 518 222 498 228C460 239 376 242 268 240C178 238 96 234 64 224C44 218 40 214 52 200Z" fill="#C9A96E"/><path d="M258 102C262 76 266 52 270 38C274 24 282 17 292 21C304 26 306 46 302 68" stroke="#C9A96E" stroke-width="6" stroke-linecap="round" fill="none"/></svg></div>
      <div class="sbody">
        <div class="sorg">Mallorca · Spain</div>
        <div class="sbrand">Carmina</div>
        <div class="ssub">Shoemaker</div>
        <div class="sdesc">Family-crafted since 1958. Ready-to-wear and made-to-order.</div>
        <a href="https://curatedandcobkk.com/product-category/brands/carmina/" class="sbtn">Shop Carmina</a>
      </div>
    </div>
    <div class="slide s3">
      <div class="sacc"></div>
      <div class="sart" aria-hidden="true"><svg viewBox="0 0 560 280" fill="none"><path d="M40 195C70 130 158 100 250 97C306 95 360 105 406 128C452 151 496 178 510 195C522 208 516 224 494 230C454 240 368 244 260 242C168 240 88 236 58 226C36 219 28 210 40 195Z" fill="#C9A96E"/><path d="M250 97C253 74 256 56 260 44C264 32 272 26 280 29" stroke="#C9A96E" stroke-width="7" stroke-linecap="round" fill="none"/></svg></div>
      <div class="sbody">
        <div class="sorg">Romans-sur-Isere · France</div>
        <div class="sbrand">Paraboot</div>
        <div class="ssub">Since 1908</div>
        <div class="sdesc">Norwegian welt. Made in France. Built to last decades.</div>
        <a href="https://curatedandcobkk.com/product-category/brands/paraboot/" class="sbtn">Shop Paraboot</a>
      </div>
    </div>
  </div>
  <div class="hero-dots" id="dots">
    <button class="dot on" data-i="0"></button>
    <button class="dot" data-i="1"></button>
    <button class="dot" data-i="2"></button>
    <button class="dot" data-i="3"></button>
  </div>
</div>
<div class="bstrip">
  <div class="bstrip-lbl">Our Brands</div>
  <div class="bstrip-list">
    <a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="on">Berwick</a>
    <span class="bstrip-sep">·</span>
    <a href="https://curatedandcobkk.com/product-category/brands/carmina/">Carmina</a>
    <span class="bstrip-sep">·</span>
    <a href="https://curatedandcobkk.com/product-category/brands/paraboot/">Paraboot</a>
  </div>
</div>
<section class="col">
  <div class="sec-hd"><span class="sec-ey rv">The Edit</span><h2 class="sec-h2 rv d1">Selected<br/><em>for Bangkok</em></h2></div>
  <div class="bblock rv d1">
    <div class="brow-hd"><div class="brow-name">Berwick 1707</div><div class="brow-rule"></div><a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="brow-link">View All</a></div>
    <div class="card-row">
      <a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="pcard"><div class="pcard-img"><div class="ph g1"><svg viewBox="0 0 300 200" fill="none"><path d="M28 138C50 94 110 72 166 68C200 66 234 72 262 86C290 100 308 118 314 130C320 140 316 150 302 155C276 162 224 165 164 163C114 161 64 158 44 152C30 147 22 145 28 138Z" fill="#C9A96E"/><rect x="138" y="52" width="70" height="18" rx="4" fill="#C9A96E" opacity="0.5"/></svg><div class="ph-tag">Penny Loafer</div><div class="ph-badge">New</div></div></div><div class="pcard-brand">Berwick 1707</div><div class="pcard-name">9628 Box Calf</div><div class="pcard-note">Goodyear welted · Last 8</div><div class="pcard-price">฿8,800</div></a>
      <a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="pcard"><div class="pcard-img"><div class="ph g2"><svg viewBox="0 0 300 200" fill="none"><path d="M28 138C50 94 110 72 166 68C200 66 234 72 262 86C290 100 308 118 314 130C320 140 316 150 302 155C276 162 224 165 164 163C114 161 64 158 44 152C30 147 22 145 28 138Z" fill="#C9A96E"/><rect x="142" y="46" width="62" height="10" rx="3" fill="#C9A96E" opacity="0.65"/></svg><div class="ph-tag">Horsebit</div></div></div><div class="pcard-brand">Berwick 1707</div><div class="pcard-name">Horsebit Suede</div><div class="pcard-note">Unlined · Blake stitch</div><div class="pcard-price">฿7,500</div></a>
      <a href="https://curatedandcobkk.com/product-category/brands/berwick/" class="pcard"><div class="pcard-img"><div class="ph g3"><svg viewBox="0 0 300 200" fill="none"><path d="M30 140C52 96 112 74 168 70C202 68 236 74 264 88C292 102 308 120 314 132C320 142 314 152 298 157C272 164 218 167 158 165C108 163 58 160 38 154C24 149 18 147 30 140Z" fill="#C9A96E"/><path d="M168 70C172 48 175 32 178 22C182 12 190 8 198 11C208 15 210 32 207 52" stroke="#C9A96E" stroke-width="4" stroke-linecap="round" fill="none"/></svg><div class="ph-tag">Oxford</div><div class="ph-badge">Cordovan</div></div></div><div class="pcard-brand">Berwick 1707</div><div class="pcard-name">Shell Cordovan</div><div class="pcard-note">Goodyear welt · Rois calf</div><div class="pcard-price">฿12,800</div></a>
    </div>
