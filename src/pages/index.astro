const cat3 = {"tag":"Berwick 1707","name1":"Flex","name2":"Walks","desc":"Blake-stitched comfort for the Bangkok lifestyle — lighter, more flexible, just as refined","url":"https://curatedandcobkk.com/product-category/berwick-flex-walks/"};
