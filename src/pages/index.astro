  </div>
</section>

<!-- JOURNAL — full width editorial -->
<section class="journal-sec">
  <div class="sec-hd">
    <span class="sec-ey rv">Stories</span>
    <h2 class="sec-h2 rv d1">Journal<br/><em>& Stories</em></h2>
